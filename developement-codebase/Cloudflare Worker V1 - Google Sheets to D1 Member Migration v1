const WORKER_VERSION = "1.0.0";
const DEFAULT_BATCH_SIZE = 500;
const DEFAULT_TEST_MODE = true;
const DEFAULT_TEST_SHEET_ROW = 2;
const DEFAULT_WORKSHEET_NAME = "members";
const DEFAULT_MAX_RETRIES = 4;
const DEFAULT_INITIAL_RETRY_DELAY_MS = 500;
const DEFAULT_PRODUCTION_D1_BINDING_NAME = "PRODUCTION_DB";
const DEFAULT_INTERMEDIATE_D1_BINDING_NAME = "MIGRATION_DB";
const DEFAULT_ACTIVATION_BASE_URL = "https://kenfolios.com/activate";
const DEFAULT_ORDER_BASE_URL = "https://kenfolios.com/order";
const DEFAULT_ACTIVATION_CURRENCY = "INR";

const GOOGLE_TOKEN_URL = "https://oauth2.googleapis.com/token";
const GOOGLE_SHEETS_API_BASE = "https://sheets.googleapis.com/v4/spreadsheets";
const GOOGLE_SHEETS_SCOPE = "https://www.googleapis.com/auth/spreadsheets.readonly";
const JWT_GRANT_TYPE = "urn:ietf:params:oauth:grant-type:jwt-bearer";
const JWT_LIFETIME_SECONDS = 3600;

const ACTIONS = Object.freeze({
  CREATE_PAID: "CREATE_PAID",
  CREATE_UNPAID: "CREATE_UNPAID",
  UPGRADE_TO_PAID: "UPGRADE_TO_PAID",
  SKIP_ALREADY_PAID: "SKIP_ALREADY_PAID",
  SKIP_ALREADY_UNPAID: "SKIP_ALREADY_UNPAID",
  ERROR: "ERROR",
});

const MIGRATION_STATUS = Object.freeze({
  PENDING: "PENDING",
  SUCCESS: "SUCCESS",
  FAILED: "FAILED",
  NOT_WRITTEN: "NOT_WRITTEN",
  RETRYING: "RETRYING",
});

const HTTP_STATUS = Object.freeze({
  OK: 200,
  BAD_REQUEST: 400,
  NOT_FOUND: 404,
  METHOD_NOT_ALLOWED: 405,
  INTERNAL_SERVER_ERROR: 500,
});

function getRuntimeConfig() {
  const config = {
    workerVersion: getTextVar("WORKER_VERSION", WORKER_VERSION),
    batchSize: getIntegerVar("BATCH_SIZE", DEFAULT_BATCH_SIZE),
    testMode: getBooleanVar("TEST_MODE", DEFAULT_TEST_MODE),
    testSheetRow: getIntegerVar("TEST_SHEET_ROW", DEFAULT_TEST_SHEET_ROW),
    googleSheetId: getRequiredTextVar("GOOGLE_SHEET_ID"),
    worksheetName: getTextVar("WORKSHEET_NAME", DEFAULT_WORKSHEET_NAME),
    maxRetries: getIntegerVar("MAX_RETRIES", DEFAULT_MAX_RETRIES),
    initialRetryDelayMs: getIntegerVar(
      "INITIAL_RETRY_DELAY_MS",
      DEFAULT_INITIAL_RETRY_DELAY_MS
    ),
    productionBindingName: getTextVar(
      "PRODUCTION_D1_BINDING_NAME",
      DEFAULT_PRODUCTION_D1_BINDING_NAME
    ),
    intermediateBindingName: getTextVar(
      "INTERMEDIATE_D1_BINDING_NAME",
      DEFAULT_INTERMEDIATE_D1_BINDING_NAME
    ),
    activationBaseUrl: getTextVar("ACTIVATION_BASE_URL", DEFAULT_ACTIVATION_BASE_URL),
    orderBaseUrl: getTextVar("ORDER_BASE_URL", DEFAULT_ORDER_BASE_URL),
    defaultCurrency: getTextVar(
      "DEFAULT_ACTIVATION_CURRENCY",
      DEFAULT_ACTIVATION_CURRENCY
    ),
    defaultActivationAmount: getNullableIntegerVar("DEFAULT_ACTIVATION_AMOUNT"),
    defaultActivationDiscountAmount:
      getNullableIntegerVar("DEFAULT_ACTIVATION_DISCOUNT_AMOUNT") || 0,
  };

  if (config.batchSize <= 0) {
    throw new Error("BATCH_SIZE must be greater than zero.");
  }

  if (config.testMode && config.testSheetRow < 2) {
    throw new Error("TEST_SHEET_ROW must be a Google Sheet data row number, starting at 2.");
  }

  return config;
}

function getDatabases(config) {
  const productionDb = globalThis[config.productionBindingName];
  const intermediateDb = globalThis[config.intermediateBindingName];

  if (!productionDb) {
    throw new Error(`Missing production D1 binding: ${config.productionBindingName}`);
  }

  if (!intermediateDb) {
    throw new Error(`Missing intermediate D1 binding: ${config.intermediateBindingName}`);
  }

  return { productionDb, intermediateDb };
}

function getTextVar(name, fallback) {
  const value = globalThis[name];

  if (value === undefined || value === null || String(value).trim() === "") {
    return fallback;
  }

  return String(value).trim();
}

function getRequiredTextVar(name) {
  const value = getTextVar(name, null);

  if (!value) {
    throw new Error(`Missing required environment variable: ${name}`);
  }

  return value;
}

function getBooleanVar(name, fallback) {
  const value = globalThis[name];

  if (value === undefined || value === null || String(value).trim() === "") {
    return fallback;
  }

  return String(value).trim().toLowerCase() === "true";
}

function getIntegerVar(name, fallback) {
  const value = globalThis[name];

  if (value === undefined || value === null || String(value).trim() === "") {
    return fallback;
  }

  const parsed = Number.parseInt(String(value), 10);

  return Number.isNaN(parsed) ? fallback : parsed;
}

function getNullableIntegerVar(name) {
  const value = globalThis[name];

  if (value === undefined || value === null || String(value).trim() === "") {
    return null;
  }

  const parsed = Number.parseInt(String(value), 10);

  return Number.isNaN(parsed) ? null : parsed;
}

/******************************************************************
 GENERAL UTILITIES
******************************************************************/

function nowIso() {
  return new Date().toISOString();
}

function jsonResponse(payload, status) {
  return new Response(JSON.stringify(payload, null, 2), {
    status: status || HTTP_STATUS.OK,
    headers: { "content-type": "application/json; charset=utf-8" },
  });
}

function formatError(error) {
  return {
    name: error && error.name ? error.name : "Error",
    message: error && error.message ? error.message : String(error),
    stack: error && error.stack ? error.stack : null,
  };
}

function safeJson(value) {
  return JSON.stringify(value === undefined ? null : value);
}

function parseJson(value) {
  if (!value) {
    return null;
  }

  try {
    return JSON.parse(value);
  } catch {
    return null;
  }
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function logEvent(event, details) {
  console.log(JSON.stringify({
    event,
    ...(details || {}),
    logged_at: nowIso(),
  }));
}

/******************************************************************
 GOOGLE SHEETS
******************************************************************/

async function readHeaderRow(config) {
  const range = `${escapeSheetName(config.worksheetName)}!1:1`;
  const values = await readSheetValues(config, range);

  return (values[0] || []).map((name) => String(name || "").trim());
}

async function readSheetRows(config, startRowNumber, rowCount, header) {
  const lastColumn = columnLetter(Math.max(header.length - 1, 0));
  const endRowNumber = startRowNumber + rowCount - 1;
  const range =
    `${escapeSheetName(config.worksheetName)}!A${startRowNumber}:${lastColumn}${endRowNumber}`;
  const values = await readSheetValues(config, range);

  return values.map((row, index) => ({
    sourceRowNumber: startRowNumber + index,
    rawValues: row,
    rawObject: rowToObject(header, row),
  }));
}

async function readSheetValues(config, range) {
  const accessToken = await getGoogleAccessToken(config);
  const endpoint =
    `${GOOGLE_SHEETS_API_BASE}/${encodeURIComponent(config.googleSheetId)}` +
    `/values/${encodeURIComponent(range)}` +
    "?majorDimension=ROWS&valueRenderOption=UNFORMATTED_VALUE&dateTimeRenderOption=FORMATTED_STRING";

  return retry(config, async () => {
    const response = await fetch(endpoint, {
      headers: { authorization: `Bearer ${accessToken}` },
    });

    if (!response.ok) {
      throw new Error(`Google Sheets read failed: ${response.status} ${await response.text()}`);
    }

    const payload = await response.json();

    return payload.values || [];
  });
}

async function getGoogleAccessToken(config) {
  const serviceAccountEmail =
    getTextVar("GOOGLE_SERVICE_ACCOUNT_EMAIL", null) ||
    getTextVar("GOOGLE_CLIENT_EMAIL", null);
  const privateKey = normalizePrivateKey(getTextVar("GOOGLE_PRIVATE_KEY", null));

  if (!serviceAccountEmail) {
    throw new Error("Missing GOOGLE_SERVICE_ACCOUNT_EMAIL or GOOGLE_CLIENT_EMAIL.");
  }

  if (!privateKey) {
    throw new Error("Missing GOOGLE_PRIVATE_KEY.");
  }

  const issuedAt = Math.floor(Date.now() / 1000);
  const claimSet = {
    iss: serviceAccountEmail,
    scope: GOOGLE_SHEETS_SCOPE,
    aud: GOOGLE_TOKEN_URL,
    exp: issuedAt + JWT_LIFETIME_SECONDS,
    iat: issuedAt,
  };
  const assertion = await signGoogleJwt(claimSet, privateKey);
  const body = new URLSearchParams();
  body.set("grant_type", JWT_GRANT_TYPE);
  body.set("assertion", assertion);

  return retry(config, async () => {
    const response = await fetch(GOOGLE_TOKEN_URL, {
      method: "POST",
      headers: { "content-type": "application/x-www-form-urlencoded" },
      body,
    });

    if (!response.ok) {
      throw new Error(`Google OAuth failed: ${response.status} ${await response.text()}`);
    }

    const payload = await response.json();

    if (!payload.access_token) {
      throw new Error("Google OAuth response did not include an access_token.");
    }

    return payload.access_token;
  });
}

async function signGoogleJwt(claimSet, privateKeyPem) {
  const encodedHeader = base64UrlEncode(JSON.stringify({ alg: "RS256", typ: "JWT" }));
  const encodedClaimSet = base64UrlEncode(JSON.stringify(claimSet));
  const unsignedToken = `${encodedHeader}.${encodedClaimSet}`;
  const key = await crypto.subtle.importKey(
    "pkcs8",
    pemToArrayBuffer(privateKeyPem),
    { name: "RSASSA-PKCS1-v1_5", hash: "SHA-256" },
    false,
    ["sign"]
  );
  const signature = await crypto.subtle.sign(
    "RSASSA-PKCS1-v1_5",
    key,
    new TextEncoder().encode(unsignedToken)
  );

  return `${unsignedToken}.${base64UrlEncode(signature)}`;
}

function rowToObject(header, row) {
  const output = {};

  header.forEach((name, index) => {
    if (name) {
      output[name] = row[index] === undefined ? "" : row[index];
    }
  });

  return output;
}

function escapeSheetName(sheetName) {
  return `'${String(sheetName).replace(/'/g, "''")}'`;
}

function columnLetter(index) {
  let letter = "";
  let value = index + 1;

  while (value > 0) {
    const remainder = (value - 1) % 26;
    letter = String.fromCharCode(65 + remainder) + letter;
    value = Math.floor((value - 1) / 26);
  }

  return letter;
}

function normalizePrivateKey(value) {
  return value ? String(value).replace(/\\n/g, "\n").trim() : null;
}

function pemToArrayBuffer(pem) {
  const base64 = pem
    .replace(/-----BEGIN PRIVATE KEY-----/g, "")
    .replace(/-----END PRIVATE KEY-----/g, "")
    .replace(/\s+/g, "");
  const binary = atob(base64);
  const bytes = new Uint8Array(binary.length);

  for (let index = 0; index < binary.length; index += 1) {
    bytes[index] = binary.charCodeAt(index);
  }

  return bytes.buffer;
}

function base64UrlEncode(value) {
  const bytes =
    typeof value === "string" ? new TextEncoder().encode(value) : new Uint8Array(value);
  let binary = "";

  for (const byte of bytes) {
    binary += String.fromCharCode(byte);
  }

  return btoa(binary).replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/g, "");
}

async function retry(config, operation) {
  let lastError = null;

  for (let attempt = 1; attempt <= config.maxRetries; attempt += 1) {
    try {
      return await operation();
    } catch (error) {
      lastError = error;

      if (attempt === config.maxRetries) {
        break;
      }

      await sleep(config.initialRetryDelayMs * 2 ** (attempt - 1));
    }
  }

  throw lastError;
}

/******************************************************************
 DATA CLEANING
******************************************************************/

function normalizeString(value) {
  if (value === undefined || value === null) {
    return null;
  }

  const normalized = String(value).trim();

  return normalized === "" ? null : normalized;
}

function normalizeEmail(value) {
  const normalized = normalizeString(value);

  return normalized ? normalized.toLowerCase() : null;
}

function normalizePhone(value) {
  const normalized = normalizeString(value);

  if (!normalized) {
    return null;
  }

  return normalized.replace(/^p\s*:\s*/i, "").trim() || null;
}

function normalizePincode(value) {
  const normalized = normalizeString(value);

  if (!normalized) {
    return null;
  }

  return normalized.replace(/^z\s*:\s*/i, "").trim() || null;
}

function isValidEmail(email) {
  return Boolean(email && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email));
}

function parseAmount(value) {
  const normalized = normalizeString(value);

  if (!normalized) {
    return null;
  }

  const numeric = Number(String(normalized).replace(/,/g, ""));

  return Number.isFinite(numeric) ? Math.round(numeric) : null;
}

