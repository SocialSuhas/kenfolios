async function runMigration(options) {
  const config = options.config;
  const productionDb = options.productionDb;
  const intermediateDb = options.intermediateDb;
  const trigger = options.trigger;
  const startedAtMs = Date.now();
  const runId = crypto.randomUUID();
  const mode = config.testMode ? "TEST" : "LIVE";
  const summary = createRunSummary(runId, mode, trigger);

  await startRun(intermediateDb, runId, mode, config.workerVersion);

  logEvent("migration_run_started", {
    run_id: runId,
    mode,
    trigger,
    batch_size: config.batchSize,
  });

  try {
    if (!config.testMode) {
      await drainPendingProductionWrites(config, productionDb, intermediateDb, summary);
    }

    if (config.testMode || summary.rowsProcessed < config.batchSize) {
      const remainingCapacity = config.testMode
        ? config.batchSize
        : config.batchSize - summary.rowsProcessed;

      await scanSheetBatch(
        config,
        productionDb,
        intermediateDb,
        runId,
        summary,
        remainingCapacity
      );
    }
  } catch (error) {
    summary.success = false;
    summary.error = formatError(error);
    summary.rowsFailed += 1;
    logEvent("migration_run_failed", {
      run_id: runId,
      error: formatError(error),
    });
  }

  const completion = await completeRun(intermediateDb, runId, startedAtMs, summary);
  summary.completedAt = completion.completedAt;
  summary.durationMs = completion.durationMs;

  logEvent("migration_run_completed", {
    run_id: runId,
    mode,
    rows_scanned: summary.rowsScanned,
    rows_processed: summary.rowsProcessed,
    rows_written: summary.rowsCreated + summary.rowsUpgraded,
    rows_skipped: summary.rowsSkipped,
    rows_failed: summary.rowsFailed,
    duration_ms: summary.durationMs,
  });

  return summary;
}

async function scanSheetBatch(config, productionDb, intermediateDb, runId, summary, rowCount) {
  const state = await getMigrationState(intermediateDb);
  const startRowNumber = Math.max(2, Number(state.last_scanned_sheet_row || 1) + 1);
  const header = await readHeaderRow(config);
  const sheetRows = await readSheetRows(config, startRowNumber, rowCount, header);
  const batchSeenEmails = new Set();

  for (const sheetRow of sheetRows) {
    try {
      const mappedMember = mapSourceRow(sheetRow);
      const decision = await determineEligibility({
        mappedMember,
        productionDb,
        intermediateDb,
        batchSeenEmails,
      });

      if (mappedMember.email) {
        batchSeenEmails.add(mappedMember.email);
      }

      await handleScannedRow(
        config,
        productionDb,
        intermediateDb,
        runId,
        sheetRow,
        mappedMember,
        decision,
        summary
      );

      summary.rowsScanned += 1;
      summary.rowsProcessed += 1;
      await updateLastScannedSheetRow(intermediateDb, sheetRow.sourceRowNumber);
    } catch (error) {
      summary.rowsScanned += 1;
      summary.rowsProcessed += 1;
      summary.rowsFailed += 1;

      await saveAuditRow(intermediateDb, {
        action_required: ACTIONS.ERROR,
        migration_status: MIGRATION_STATUS.FAILED,
        action_reason: "Row processing failed.",
        source_row_number: sheetRow.sourceRowNumber,
        email: null,
        phone: null,
        source_payment_status: null,
        target_payment_status: null,
        target_member_id: null,
        generated_reference_id: null,
        generated_unique_token: null,
        generated_activation_url: null,
        generated_order_url: null,
        generated_gateway_order_id: null,
        generated_gateway_payment_id: null,
        processed_at: nowIso(),
        production_written_at: null,
        error_message: error.message,
        source_json: sheetRow.rawObject,
        mapped_member_json: null,
        run_id: runId,
      });

      await updateLastScannedSheetRow(intermediateDb, sheetRow.sourceRowNumber);
    }
  }
}

async function handleScannedRow(
  config,
  productionDb,
  intermediateDb,
  runId,
  sheetRow,
  mappedMember,
  decision,
  summary
) {
  const shouldWriteProduction =
    isProductionAction(decision.action) &&
    (!config.testMode || sheetRow.sourceRowNumber === config.testSheetRow);
  const initialStatus = resolveInitialStatus(config, decision, sheetRow.sourceRowNumber);

  await saveAuditRow(intermediateDb, {
    action_required: decision.action,
    migration_status: initialStatus,
    action_reason: resolveActionReason(config, decision, sheetRow.sourceRowNumber),
    source_row_number: sheetRow.sourceRowNumber,
    email: mappedMember.email,
    phone: mappedMember.phone,
    source_payment_status: mappedMember.source_payment_status,
    target_payment_status: mappedMember.target_payment_status,
    target_member_id: decision.targetMember ? decision.targetMember.id : null,
    generated_reference_id: null,
    generated_unique_token: null,
    generated_activation_url: null,
    generated_order_url: null,
    generated_gateway_order_id: mappedMember.legacy_gateway_order_id,
    generated_gateway_payment_id: mappedMember.legacy_gateway_payment_id,
    processed_at: nowIso(),
    production_written_at: null,
    error_message: null,
    source_json: sheetRow.rawObject,
    mapped_member_json: mappedMember,
    run_id: runId,
  });

  if (decision.action === ACTIONS.ERROR) {
    summary.rowsFailed += 1;
    return;
  }

  if (!isProductionAction(decision.action)) {
    summary.rowsSkipped += 1;
    await updateLastWrittenSheetRow(intermediateDb, sheetRow.sourceRowNumber);
    return;
  }

  if (!shouldWriteProduction) {
    summary.rowsSkipped += 1;
    return;
  }

  await writeProductionAndMarkAudit({
    config,
    productionDb,
    intermediateDb,
    mappedMember,
    action: decision.action,
    targetMemberId: decision.targetMember ? decision.targetMember.id : null,
    sourceRowNumber: sheetRow.sourceRowNumber,
    summary,
  });
}

async function drainPendingProductionWrites(config, productionDb, intermediateDb, summary) {
  const pendingRows = await getPendingProductionRows(intermediateDb, config.batchSize);

  for (const row of pendingRows) {
    if (summary.rowsProcessed >= config.batchSize) {
      return;
    }

    const mappedMember = row.mapped_member_json;
    const decision = await determineEligibility({
      mappedMember,
      productionDb,
      intermediateDb,
      batchSeenEmails: new Set(),
    });

    if (!isProductionAction(decision.action) || decision.action === ACTIONS.ERROR) {
      await saveAuditRow(intermediateDb, {
        action_required: decision.action,
        migration_status:
          decision.action === ACTIONS.ERROR ? MIGRATION_STATUS.FAILED : MIGRATION_STATUS.SUCCESS,
        action_reason: decision.reason,
        source_row_number: row.source_row_number,
        email: mappedMember && mappedMember.email ? mappedMember.email : row.email,
        phone: mappedMember && mappedMember.phone ? mappedMember.phone : row.phone,
        source_payment_status:
          mappedMember && mappedMember.source_payment_status
            ? mappedMember.source_payment_status
            : row.source_payment_status,
        target_payment_status:
          mappedMember && mappedMember.target_payment_status
            ? mappedMember.target_payment_status
            : row.target_payment_status,
        target_member_id: decision.targetMember ? decision.targetMember.id : row.target_member_id,
        generated_reference_id: row.generated_reference_id,
        generated_unique_token: row.generated_unique_token,
        generated_activation_url: row.generated_activation_url,
        generated_order_url: row.generated_order_url,
        generated_gateway_order_id: row.generated_gateway_order_id,
        generated_gateway_payment_id: row.generated_gateway_payment_id,
        processed_at: nowIso(),
        production_written_at: row.production_written_at,
        error_message: decision.action === ACTIONS.ERROR ? decision.reason : null,
        source_json: row.source_json,
        mapped_member_json: mappedMember,
        run_id: summary.runId,
      });

      if (decision.action === ACTIONS.ERROR) {
        summary.rowsFailed += 1;
      } else {
        summary.rowsSkipped += 1;
      }

      summary.rowsProcessed += 1;
      continue;
    }

    await writeProductionAndMarkAudit({
      config,
      productionDb,
      intermediateDb,
      mappedMember,
      action: decision.action,
      targetMemberId: decision.targetMember ? decision.targetMember.id : row.target_member_id,
      sourceRowNumber: row.source_row_number,
      summary,
    });
    summary.rowsProcessed += 1;
  }
}

async function writeProductionAndMarkAudit(options) {
  const config = options.config;
  const productionDb = options.productionDb;
  const intermediateDb = options.intermediateDb;
  const mappedMember = options.mappedMember;
  const action = options.action;
  const targetMemberId = options.targetMemberId;
  const sourceRowNumber = options.sourceRowNumber;
  const summary = options.summary;

  try {
    const result = await writeMemberToProduction({
      config,
      productionDb,
      mappedMember,
      action,
      targetMemberId,
    });
    const generatedFields = buildAuditGeneratedFields(result.generated);

    await markAuditRowGeneratedFields(intermediateDb, sourceRowNumber, generatedFields);
    await markAuditRowSuccess(intermediateDb, sourceRowNumber, result.memberId);
    await updateLastWrittenSheetRow(intermediateDb, sourceRowNumber);

    if (action === ACTIONS.UPGRADE_TO_PAID) {
      summary.rowsUpgraded += 1;
    } else {
      summary.rowsCreated += 1;
    }
  } catch (error) {
    await markAuditRowFailed(intermediateDb, sourceRowNumber, error);
    summary.rowsFailed += 1;
    logEvent("production_write_failed", {
      source_row_number: sourceRowNumber,
      action,
      error: formatError(error),
    });
  }
}

function resolveInitialStatus(config, decision, sourceRowNumber) {
  if (decision.action === ACTIONS.ERROR) {
    return MIGRATION_STATUS.FAILED;
  }

  if (!isProductionAction(decision.action)) {
    return MIGRATION_STATUS.SUCCESS;
  }

  if (config.testMode && sourceRowNumber !== config.testSheetRow) {
    return MIGRATION_STATUS.NOT_WRITTEN;
  }

  return MIGRATION_STATUS.PENDING;
}

function resolveActionReason(config, decision, sourceRowNumber) {
  if (!config.testMode || !isProductionAction(decision.action)) {
    return decision.reason;
  }

  if (sourceRowNumber === config.testSheetRow) {
    return "Configured test row written.";
  }

  return "Test mode skipped production write.";
}

function createRunSummary(runId, mode, trigger) {
  return {
    success: true,
    runId,
    mode,
    trigger,
    rowsScanned: 0,
    rowsProcessed: 0,
    rowsCreated: 0,
    rowsUpgraded: 0,
    rowsSkipped: 0,
    rowsFailed: 0,
    startedAt: nowIso(),
    completedAt: null,
    durationMs: null,
  };
}

/******************************************************************
 CRON HANDLER
******************************************************************/

addEventListener("fetch", (event) => {
  event.respondWith(handleFetchRequest(event.request));
});

addEventListener("scheduled", (event) => {
  event.waitUntil(handleScheduledRun(event));
});

async function handleFetchRequest(request) {
  try {
    const url = new URL(request.url);

    if (request.method !== "GET" && request.method !== "POST") {
      return jsonResponse(
        { success: false, error: "Method Not Allowed" },
        HTTP_STATUS.METHOD_NOT_ALLOWED
      );
    }

    const config = getRuntimeConfig();
    const databases = getDatabases(config);

    await initializeIntermediateDb(databases.intermediateDb);

    if (url.pathname === "/" || url.pathname === "/health") {
      return jsonResponse({
        success: true,
        worker_name: "Google Sheets to D1 Member Migration",
        worker_version: config.workerVersion,
        mode: config.testMode ? "TEST" : "LIVE",
        batch_size: config.batchSize,
        worksheet_name: config.worksheetName,
        test_sheet_row: config.testSheetRow,
        production_binding_name: config.productionBindingName,
        intermediate_binding_name: config.intermediateBindingName,
      });
    }

    if (url.pathname === "/run") {
      return jsonResponse(
        await runMigration({
          config,
          productionDb: databases.productionDb,
          intermediateDb: databases.intermediateDb,
          trigger: "http",
        })
      );
    }

    return jsonResponse({ success: false, error: "Not Found" }, HTTP_STATUS.NOT_FOUND);
  } catch (error) {
    return jsonResponse(
      {
        success: false,
        error: error.message,
        details: formatError(error),
      },
      HTTP_STATUS.INTERNAL_SERVER_ERROR
    );
  }
}

async function handleScheduledRun(event) {
  const config = getRuntimeConfig();
  const databases = getDatabases(config);

  await initializeIntermediateDb(databases.intermediateDb);
  await runMigration({
    config,
    productionDb: databases.productionDb,
    intermediateDb: databases.intermediateDb,
    trigger: "scheduled",
    scheduledTime: event && event.scheduledTime ? event.scheduledTime : null,
  });
}
