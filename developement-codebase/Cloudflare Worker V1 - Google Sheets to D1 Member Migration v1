function mapSourceRow(sheetRow) {
  const raw = sheetRow.rawObject;
  const paymentStatus = normalizePaymentStatus(pickColumn(raw, FIELD_ALIASES.paymentStatus));

  return removeUndefinedProperties({
    source_row_number: sheetRow.sourceRowNumber,
    full_name: normalizeString(pickColumn(raw, FIELD_ALIASES.fullName)) || "Unknown Member",
    email: normalizeEmail(pickColumn(raw, FIELD_ALIASES.email)),
    phone: normalizePhone(pickColumn(raw, FIELD_ALIASES.phone)),
    dob: normalizeString(pickColumn(raw, FIELD_ALIASES.dob)),
    gender: normalizeString(pickColumn(raw, FIELD_ALIASES.gender)),
    city: normalizeString(pickColumn(raw, FIELD_ALIASES.city)),
    country: normalizeString(pickColumn(raw, FIELD_ALIASES.country)) || "India",
    pincode: normalizePincode(pickColumn(raw, FIELD_ALIASES.pincode)),
    expectations: normalizeString(pickColumn(raw, FIELD_ALIASES.expectations)),
    business_category: normalizeString(pickColumn(raw, FIELD_ALIASES.businessCategory)),
    business_name: normalizeString(pickColumn(raw, FIELD_ALIASES.businessName)),
    gst_number: normalizeString(pickColumn(raw, FIELD_ALIASES.gstNumber)),
    source_payment_status: paymentStatus.sourceValue,
    source_is_paid: paymentStatus.isPaid,
    target_payment_status: paymentStatus.targetFeeStatus,
    target_gateway_status: paymentStatus.targetGatewayStatus,
    legacy_gateway_order_id: normalizeString(pickColumn(raw, FIELD_ALIASES.gatewayOrderId)),
    legacy_gateway_payment_id: normalizeString(pickColumn(raw, FIELD_ALIASES.gatewayPaymentId)),
    legacy_gateway_signature: normalizeString(pickColumn(raw, FIELD_ALIASES.gatewaySignature)),
    legacy_amount_original: parseAmount(pickColumn(raw, FIELD_ALIASES.amountOriginal)),
    legacy_discount_amount: parseAmount(pickColumn(raw, FIELD_ALIASES.discountAmount)),
    legacy_amount_final: parseAmount(pickColumn(raw, FIELD_ALIASES.amountFinal)),
    legacy_coupon_code: normalizeString(pickColumn(raw, FIELD_ALIASES.couponCode)),
    legacy_paid_at: normalizeString(pickColumn(raw, FIELD_ALIASES.paidAt)),
    legacy_receipt: normalizeString(pickColumn(raw, FIELD_ALIASES.receipt)),
  });
}

function normalizePaymentStatus(value) {
  const normalized = normalizeString(value);
  const lowered = normalized ? normalized.toLowerCase() : null;
  const isPaid = lowered === "captured" || lowered === "paid";

  return {
    sourceValue: normalized,
    isPaid,
    targetFeeStatus: isPaid ? "paid" : "pending",
    targetGatewayStatus: isPaid ? "captured" : "pending",
  };
}

function pickColumn(row, aliases) {
  for (const alias of aliases) {
    if (Object.prototype.hasOwnProperty.call(row, alias)) {
      return row[alias];
    }
  }

  const loweredAliases = new Set(aliases.map((alias) => alias.toLowerCase()));

  for (const [key, value] of Object.entries(row)) {
    if (loweredAliases.has(String(key).trim().toLowerCase())) {
      return value;
    }
  }

  return null;
}

function removeUndefinedProperties(value) {
  const output = {};

  for (const [key, rawValue] of Object.entries(value)) {
    if (rawValue !== undefined) {
      output[key] = rawValue;
    }
  }

  return output;
}

/******************************************************************
 ELIGIBILITY ENGINE
******************************************************************/

async function determineEligibility(options) {
  const mappedMember = options.mappedMember;
  const productionDb = options.productionDb;
  const intermediateDb = options.intermediateDb;
  const batchSeenEmails = options.batchSeenEmails;

  if (!mappedMember || !mappedMember.email) {
    return errorDecision("Blank email.");
  }

  if (!isValidEmail(mappedMember.email)) {
    return errorDecision("Invalid email.");
  }

  if (batchSeenEmails.has(mappedMember.email)) {
    return errorDecision("Duplicate source email.");
  }

  const priorSourceDuplicate = await intermediateDb.prepare(
    `
    SELECT id
    FROM migration_rows
    WHERE email = ?
      AND source_row_number < ?
    LIMIT 1
    `
  )
    .bind(mappedMember.email, mappedMember.source_row_number)
    .first();

  if (priorSourceDuplicate) {
    return errorDecision("Duplicate source email.");
  }

  const targetMatches = await productionDb.prepare(
    `
    SELECT
      id,
      activation_fee_status,
      activation_gateway_status,
      activation_url
    FROM members
    WHERE LOWER(TRIM(email)) = ?
    LIMIT 2
    `
  )
    .bind(mappedMember.email)
    .all();
  const matches = targetMatches.results || [];

  if (matches.length > 1) {
    return errorDecision("Duplicate target email.");
  }

  if (matches.length === 0) {
    return {
      action: mappedMember.source_is_paid ? ACTIONS.CREATE_PAID : ACTIONS.CREATE_UNPAID,
      reason: mappedMember.source_is_paid
        ? "Email not found in production. Source member is paid."
        : "Email not found in production. Source member is unpaid.",
      targetMember: null,
    };
  }

  const targetMember = matches[0];
  const targetIsPaid = isTargetPaid(targetMember);

  if (!targetIsPaid && mappedMember.source_is_paid) {
    return {
      action: ACTIONS.UPGRADE_TO_PAID,
      reason: "Existing member unpaid. Source member is paid.",
      targetMember,
    };
  }

  if (targetIsPaid && mappedMember.source_is_paid) {
    return {
      action: ACTIONS.SKIP_ALREADY_PAID,
      reason: "Existing member already paid.",
      targetMember,
    };
  }

  return {
    action: ACTIONS.SKIP_ALREADY_UNPAID,
    reason: "Existing member already unpaid.",
    targetMember,
  };
}

function isProductionAction(action) {
  return (
    action === ACTIONS.CREATE_PAID ||
    action === ACTIONS.CREATE_UNPAID ||
    action === ACTIONS.UPGRADE_TO_PAID
  );
}

function errorDecision(reason) {
  return {
    action: ACTIONS.ERROR,
    reason,
    targetMember: null,
  };
}

function isTargetPaid(member) {
  return (
    String(member.activation_fee_status || "").toLowerCase() === "paid" ||
    String(member.activation_gateway_status || "").toLowerCase() === "captured" ||
    Boolean(member.activation_url)
  );
}

