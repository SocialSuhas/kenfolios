async function writeMemberToProduction(options) {
  const config = options.config;
  const productionDb = options.productionDb;
  const mappedMember = options.mappedMember;
  const action = options.action;
  const targetMemberId = options.targetMemberId;
  const values = await buildMemberValues(config, mappedMember, action);

  if (action === ACTIONS.CREATE_PAID || action === ACTIONS.CREATE_UNPAID) {
    return createMember(productionDb, values);
  }

  if (action === ACTIONS.UPGRADE_TO_PAID) {
    return upgradeMemberToPaid(productionDb, targetMemberId, values);
  }

  throw new Error(`Action is not a production write action: ${action}`);
}

async function createMember(db, values) {
  const placeholders = CREATE_MEMBER_COLUMNS.map(() => "?").join(", ");
  const sql = `
    INSERT INTO members (${CREATE_MEMBER_COLUMNS.join(", ")})
    VALUES (${placeholders})
    RETURNING id
  `;
  const result = await db.prepare(sql)
    .bind(...CREATE_MEMBER_COLUMNS.map((column) => values[column] ?? null))
    .first();

  if (!result || !result.id) {
    throw new Error("Production insert did not return a member id.");
  }

  return { memberId: result.id, generated: values };
}

async function upgradeMemberToPaid(db, memberId, values) {
  if (!memberId) {
    throw new Error("Cannot upgrade member without target member id.");
  }

  const assignments = PAID_UPDATE_COLUMNS.map((column) => `${column} = ?`).join(", ");
  const sql = `
    UPDATE members
    SET ${assignments}
    WHERE id = ?
      AND (
        activation_fee_status IS NULL
        OR LOWER(activation_fee_status) <> 'paid'
      )
    RETURNING id
  `;
  const result = await db.prepare(sql)
    .bind(...PAID_UPDATE_COLUMNS.map((column) => values[column] ?? null), memberId)
    .first();

  if (!result || !result.id) {
    throw new Error("Production upgrade did not update an unpaid member.");
  }

  return { memberId: result.id, generated: values };
}

function buildAuditGeneratedFields(generated) {
  return {
    generated_reference_id: generated && generated.ref_id ? generated.ref_id : null,
    generated_unique_token: generated && generated.unique_token ? generated.unique_token : null,
    generated_activation_url:
      generated && generated.activation_url ? generated.activation_url : null,
