async function startRun(db, runId, mode, workerVersion) {
  const startedAt = nowIso();

  await db.batch([
    db.prepare(
      `
      INSERT INTO migration_runs (run_id, started_at, mode)
      VALUES (?, ?, ?)
      `
    ).bind(runId, startedAt, mode),
    db.prepare(
      `
      UPDATE migration_state
      SET current_mode = ?, worker_version = ?, last_started = ?
      WHERE id = 1
      `
    ).bind(mode, workerVersion, startedAt),
  ]);
}

async function completeRun(db, runId, startedAtMs, summary) {
  const completedAt = nowIso();
  const durationMs = Date.now() - startedAtMs;

  await db.batch([
    db.prepare(
      `
      UPDATE migration_runs
      SET
        completed_at = ?,
        duration_ms = ?,
        rows_processed = ?,
        rows_created = ?,
        rows_upgraded = ?,
        rows_skipped = ?,
        rows_failed = ?
      WHERE run_id = ?
      `
    ).bind(
      completedAt,
      durationMs,
      summary.rowsProcessed,
      summary.rowsCreated,
      summary.rowsUpgraded,
      summary.rowsSkipped,
      summary.rowsFailed,
      runId
    ),
    db.prepare(
      `
      UPDATE migration_state
      SET
        last_completed = ?,
        total_scanned = total_scanned + ?,
        total_created = total_created + ?,
        total_upgraded = total_upgraded + ?,
        total_skipped = total_skipped + ?,
        total_failed = total_failed + ?
      WHERE id = 1
      `
    ).bind(
      completedAt,
      summary.rowsScanned,
      summary.rowsCreated,
      summary.rowsUpgraded,
      summary.rowsSkipped,
      summary.rowsFailed
    ),
  ]);

  return { completedAt, durationMs };
}

