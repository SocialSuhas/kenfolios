async function buildMemberValues(config, mappedMember, action) {
  const createdAt = nowIso();
  const values = {
    full_name: mappedMember.full_name,
    dob: mappedMember.dob,
    gender: mappedMember.gender,
    city: mappedMember.city,
    email: mappedMember.email,
    phone: mappedMember.phone,
    expectations: mappedMember.expectations,
    accepted_terms: 1,
    created_at: createdAt,
    phone_opt_in_at: null,
    email_opt_in_at: null,
    account_status: "active",
    email_opt_in: 0,
    ref_id: await generateReferenceId(),
    ref_by: null,
    country: mappedMember.country,
    phone_opt_in: 0,
    payment_gateway: mappedMember.source_is_paid ? "razorpay" : null,
    payment_gateway_payment_id: mappedMember.source_is_paid
      ? mappedMember.legacy_gateway_payment_id
      : null,
    activation_fee_status: mappedMember.target_payment_status,
    activation_gateway_status: mappedMember.target_gateway_status,
    welcome_email_sent: 0,
    remail_stage: null,
    business_category: mappedMember.business_category,
    gst_number: mappedMember.gst_number,
    business_name: mappedMember.business_name,
  };

  if (!mappedMember.source_is_paid) {
    return values;
  }

  const activation = await generateActivationValues(config, mappedMember);

  return {
    ...values,
    ...activation,
    activation_fee_paid_at: mappedMember.legacy_paid_at || createdAt,
    activation_fee_currency: config.defaultCurrency,
    activation_fee_amount: mappedMember.legacy_amount_original ?? config.defaultActivationAmount,
    activation_fee_discount_amount:
      mappedMember.legacy_discount_amount ?? config.defaultActivationDiscountAmount,
    activation_fee_final_amount: mappedMember.legacy_amount_final ?? config.defaultActivationAmount,
    activation_coupon_code: mappedMember.legacy_coupon_code,
    activation_fee_status: "paid",
    activation_captured_at: mappedMember.legacy_paid_at || createdAt,
    activation_gateway_order_id: mappedMember.legacy_gateway_order_id,
    activation_gateway_payment_id: mappedMember.legacy_gateway_payment_id,
    activation_gateway_signature: mappedMember.legacy_gateway_signature,
    activation_gateway_status: "captured",
    activation_gateway_meta: JSON.stringify({
      source: "legacy_google_sheet_migration",
      source_row_number: mappedMember.source_row_number,
      action,
    }),
    activation_attempt_count: 1,
    activation_last_error: null,
    activation_webhook_received_at: mappedMember.legacy_paid_at || createdAt,
    activation_webhook_event_type: "legacy_migration",
  };
}

async function generateActivationValues(config, mappedMember) {
  const activationToken = await randomToken("act");
  const activationOrderToken = await randomToken("ord");
  const uniqueToken = await randomToken("mem");
  const receipt =
    mappedMember.legacy_receipt ||
    `legacy_${mappedMember.source_row_number}_${Date.now()}`;

  return {
    unique_token: uniqueToken,
    activation_token: activationToken,
    activation_token_created_at: nowIso(),
    activation_order_token: activationOrderToken,
    activation_receipt: receipt,
    activation_created_at: nowIso(),
    order_url: buildUrl(config.orderBaseUrl, {
      token: activationOrderToken,
      email: mappedMember.email,
    }),
    activation_url: buildUrl(config.activationBaseUrl, {
      token: activationToken,
      email: mappedMember.email,
    }),
  };
}

async function generateReferenceId() {
  return `KF-${await randomToken("", 10)}`;
}

async function randomToken(prefix, byteLength) {
  const bytes = new Uint8Array(byteLength || 18);
  crypto.getRandomValues(bytes);
  const token = Array.from(bytes, (byte) => byte.toString(16).padStart(2, "0")).join("");

  return prefix ? `${prefix}_${token}` : token.toUpperCase();
}

function buildUrl(baseUrl, params) {
  const url = new URL(baseUrl);

  for (const [key, value] of Object.entries(params)) {
    if (value) {
      url.searchParams.set(key, value);
    }
  }

  return url.toString();
}

