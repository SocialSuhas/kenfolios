/*
----------------------------------------------------------------------------
Simple Email Validator
----------------------------------------------------------------------------
*/

function isValidEmail(
    email
) {
    if (
        !hasValue(
            email
        )
    ) {
        return false;
    }

    const value =
        email.trim();

    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(
        value
    );
}

/*
----------------------------------------------------------------------------
Simple Phone Validator
----------------------------------------------------------------------------
*/

function isValidPhone(
    phone
) {
    if (
        !hasValue(
            phone
        )
    ) {
        return false;
    }

    const digits =
        phone.replace(
            /\D/g,
            ""
        );

    return (
        digits.length >=
        8
    );
}

/*
----------------------------------------------------------------------------
Normalize Phone
----------------------------------------------------------------------------
*/

function normalizePhone(
    phone
) {
    if (
        !hasValue(
            phone
        )
    ) {
        return null;
    }

    return phone.trim();
}

/*
----------------------------------------------------------------------------
Normalize Email
----------------------------------------------------------------------------
*/

function normalizeEmail(
    email
) {
    if (
        !hasValue(
            email
        )
    ) {
        return null;
    }

    return email
        .trim()
        .toLowerCase();
}

