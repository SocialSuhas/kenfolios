/*
===============================================================================
PART 4
GOOGLE CONTACTS SYNCHRONIZATION
===============================================================================
*/

async function syncGoogleContacts(
    env
) {
    validateGoogleEnvironment(env);

    const config =
        getWorkerConfiguration(env);

    const pendingResult =
        await env.CONTACTS_DB.prepare(
            `
            SELECT
                id,
                member_id,
                full_name,
                email,
                phone,
                activation_url
            FROM member_contact_sync_records
            WHERE google_contact_status = 'pending'
            ORDER BY id ASC
            LIMIT ?
            `
        )
            .bind(
                config
                    .googleContactSyncLimit
            )
            .all();

    const pendingContacts =
        pendingResult.results ||
        [];

    if (
        pendingContacts.length ===
        0
    ) {
        return {
            success: true,

            rows_loaded: 0,

            contacts_created: 0,

            contacts_failed: 0,

            contacts_left_syncing: 0,

            message:
                "No pending contacts."
        };
    }

    console.log(
        "Google pending:",
        pendingContacts.length
    );

    const accessToken =
        await getGoogleAccessToken(
            env
        );

    let contactsCreated = 0;
    let contactsFailed = 0;
    let contactsLeftSyncing = 0;

    const results = [];

    for (
        const contact
        of pendingContacts
    ) {
        /*
        ---------------------------------------------------------------
        Protect against duplicate creation.
        ---------------------------------------------------------------
        */

        const claimed =
            await markGoogleContactSyncing(
                env.CONTACTS_DB,
                contact.id
            );

        if (!claimed) {
            results.push({
                member_id:
                    contact.member_id,

                status:
                    "skipped_not_pending"
            });

            continue;
        }

        let googleContact;

        try {
            googleContact =
                await createGoogleContact(
                    accessToken,
                    contact,
                    config
                        .googleApiTimeout
                );
        } catch (error) {
            contactsFailed++;

            const errorMessage =
                getErrorMessage(
                    error
                );

            await markGoogleContactFailed(
                env.CONTACTS_DB,
                contact.id,
                errorMessage
            );

            results.push({
                member_id:
                    contact.member_id,

                status:
                    "failed",

                error:
                    errorMessage
            });

            await sleep(
                config
                    .googleContactDelay
            );

            continue;
        }

        try {
            await markGoogleContactSynced(
                env.CONTACTS_DB,
                contact.id,
                googleContact,
                contact.full_name
            );

            contactsCreated++;

            results.push({
                member_id:
                    contact.member_id,

                status:
                    "synced",

                google_contact_id:
                    googleContact
                        .resourceName
            });
        } catch (error) {
            contactsLeftSyncing++;

            const errorMessage =
                getErrorMessage(
                    error
                );

            console.error(
                "Google contact was created but D1 synced update failed. Leaving record as syncing.",
                {
                    member_id:
                        contact.member_id,

                    record_id:
                        contact.id,

                    google_contact_id:
                        googleContact
                            .resourceName,

                    error:
                        errorMessage
                }
            );

            results.push({
                member_id:
                    contact.member_id,

                status:
                    "syncing",

                google_contact_id:
                    googleContact
                        .resourceName,

                error:
                    errorMessage
            });
        }

        /*
        ---------------------------------------------------------------
        Sequential API requests.
        ---------------------------------------------------------------
        */

        await sleep(
            config
                .googleContactDelay
        );
    }

    return {
        success:
            contactsFailed ===
            0 &&
            contactsLeftSyncing ===
            0,

        rows_loaded:
            pendingContacts.length,

        contacts_created:
            contactsCreated,

        contacts_failed:
            contactsFailed,

        contacts_left_syncing:
            contactsLeftSyncing,

        results
    };
}

