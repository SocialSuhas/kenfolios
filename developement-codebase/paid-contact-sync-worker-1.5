/*
===============================================================================
KenFolios Paid Member Contact Sync Worker
Version: 1.5
-------------------------------------------------------------------------------

Purpose

1. Incrementally scan the source members table.
2. Copy paid members (activation_url present) into the contact sync database.
3. Incrementally scan payment_orders for newly captured payments.
4. Recover older member rows that become paid later.
5. Synchronize members with Google Contacts.
6. Maintain independent cursors for every stage.
7. Prevent duplicate contact creation.
8. Serve as the production foundation for future modules.
9. Accept Razorpay payment.captured webhooks as pending record producers.

Future Modules

- Google Groups
- Email Synchronization
- WhatsApp Synchronization
- Telegram Synchronization
- Drive Export
- CRM Integration

Cron scheduling is handled entirely through Cloudflare Worker settings.

===============================================================================
*/

const WORKER_VERSION = "1.5";

const GOOGLE_API_TIMEOUT_MS = 30000;
const GOOGLE_CONTACT_DELAY_MS = 150;
const RAZORPAY_WEBHOOK_PATH = "/webhook/razorpay";

export default {
    async scheduled(controller, env, ctx) {
        ctx.waitUntil(runWorker(env));
    },

    async fetch(request, env) {
        try {
            const url =
                new URL(
                    request.url
                );

            if (
                request.method ===
                    "POST" &&
                url.pathname ===
                    RAZORPAY_WEBHOOK_PATH
            ) {
                return await handleRazorpayWebhook(
                    request,
                    env
                );
            }

            const result = await runWorker(env);

            return Response.json({
                success: true,
                version: WORKER_VERSION,
                ...result
            });
        } catch (error) {
            console.error(
                "Worker execution failed.",
                error
            );

            return Response.json(
                {
                    success: false,
                    version: WORKER_VERSION,
                    error: getErrorMessage(error)
                },
                {
                    status: 500
                }
            );
        }
    }
};

/*
===============================================================================
MAIN WORKER
===============================================================================
*/

async function runWorker(env) {
    validateEnvironment(env);

    const workerStartedAt = Date.now();

    console.log("");
    console.log(
        "===================================================="
    );
    console.log(
        "KenFolios Paid Contact Sync Worker"
    );
    console.log(
        "Version:",
        WORKER_VERSION
    );
    console.log(
        "Started:",
        new Date(workerStartedAt).toISOString()
    );
    console.log(
        "===================================================="
    );

    const summary = {
        version: WORKER_VERSION,

        started_at:
            new Date(
                workerStartedAt
            ).toISOString(),

        members_sync: null,

        payment_orders_sync: null,

        google_contacts_sync: null,

        duration_ms: 0
    };

    /*
    ===============================================================
    STAGE 1
    MEMBERS TABLE
    ===============================================================
    */

    try {
        console.log("");
        console.log(
            "Starting members scan..."
        );

        summary.members_sync =
            await syncMembersTable(env);

        console.log(
            "Members scan completed."
        );
    } catch (error) {
        console.error(
            "Members scan failed.",
            error
        );

        summary.members_sync = {
            success: false,

            error:
                getErrorMessage(error)
        };
    }

    /*
    ===============================================================
    STAGE 2
    PAYMENT ORDERS
    ===============================================================
    */

    try {
        console.log("");
        console.log(
            "Starting payment order scan..."
        );

        summary.payment_orders_sync =
            await syncPaymentOrdersTable(env);

        console.log(
            "Payment order scan completed."
        );
    } catch (error) {
        console.error(
            "Payment order scan failed.",
            error
        );

        summary.payment_orders_sync = {
            success: false,

            error:
                getErrorMessage(error)
        };
    }

    /*
    ===============================================================
    STAGE 3
    GOOGLE CONTACTS
    ===============================================================
    */

    try {
        console.log("");
        console.log(
            "Starting Google Contacts sync..."
        );

        summary.google_contacts_sync =
            await syncGoogleContacts(env);

        console.log(
            "Google Contacts sync completed."
        );
    } catch (error) {
        console.error(
            "Google Contacts sync failed.",
            error
        );

        summary.google_contacts_sync = {
            success: false,

            error:
                getErrorMessage(error)
        };
    }

    summary.duration_ms =
        Date.now() -
        workerStartedAt;

    console.log("");
    console.log(
        "===================================================="
    );
    console.log(
        "Worker completed."
    );
    console.log(
        "Duration:",
        summary.duration_ms,
        "ms"
    );
    console.log(
        "===================================================="
    );

    return summary;
}

/*
===============================================================================
COMMON CONFIGURATION
===============================================================================
*/

function getWorkerConfiguration(env) {
    return {
        membersScanLimit:
            getPositiveInteger(
                env.MEMBERS_SCAN_LIMIT,
                500
            ),

        paymentOrderScanLimit:
            getPositiveInteger(
                env.PAYMENT_ORDER_SCAN_LIMIT,
                500
            ),

        paymentCaptureLagMinutes:
            getNonNegativeInteger(
                env.PAYMENT_CAPTURE_LAG_MINUTES,
                15
            ),

        googleContactSyncLimit:
            getPositiveInteger(
                env.GOOGLE_CONTACT_SYNC_LIMIT,
                25
            ),

        googleApiTimeout:
            GOOGLE_API_TIMEOUT_MS,

        googleContactDelay:
            GOOGLE_CONTACT_DELAY_MS
    };
}

/*
===============================================================================
ENVIRONMENT VALIDATION
===============================================================================
*/

function validateEnvironment(env) {
    if (!env.SOURCE_DB) {
        throw new Error(
            "Missing SOURCE_DB binding."
        );
    }

    if (!env.CONTACTS_DB) {
        throw new Error(
            "Missing CONTACTS_DB binding."
        );
    }

}

/*
===============================================================================
RAZORPAY WEBHOOK
===============================================================================
*/

async function handleRazorpayWebhook(
    request,
    env
) {
    if (!env.SOURCE_DB) {
        throw new Error(
            "Missing SOURCE_DB binding."
        );
    }

    if (!env.CONTACTS_DB) {
        throw new Error(
            "Missing CONTACTS_DB binding."
        );
    }

    if (
        !hasValue(
            env.RAZORPAY_WEBHOOK_SECRET
        )
    ) {
        throw new Error(
            "Missing RAZORPAY_WEBHOOK_SECRET."
        );
    }

    const rawBody =
        await request.text();

    const signature =
        request.headers.get(
            "x-razorpay-signature"
        );

    const signatureValid =
        await verifyRazorpayWebhookSignature(
            rawBody,
            signature,
            env.RAZORPAY_WEBHOOK_SECRET
        );

    if (!signatureValid) {
        console.error(
            "Razorpay webhook signature verification failed."
        );

        return Response.json(
            {
                success: false,
                version: WORKER_VERSION,
                error:
                    "Invalid Razorpay webhook signature."
            },
            {
                status: 401
            }
        );
    }

    const payload =
        safelyParseJson(
            rawBody
        );

    if (!payload) {
        console.error(
            "Razorpay webhook JSON parsing failed."
        );

        return Response.json(
            {
                success: false,
                version: WORKER_VERSION,
                error:
                    "Invalid Razorpay webhook JSON."
            },
            {
                status: 400
            }
        );
    }

    const event =
        normalizeNullableText(
            payload.event
        );

    if (
        event !==
        "payment.captured"
    ) {
        console.log(
            "Razorpay webhook ignored.",
            {
                event
            }
        );

        return Response.json({
            success: true,
            version: WORKER_VERSION,
            ignored: true,
            event
        });
    }

    const orderId =
        normalizeNullableText(
            payload
                ?.payload
                ?.payment
                ?.entity
                ?.order_id
        );

    if (!orderId) {
        console.error(
            "Razorpay payment.captured webhook missing order_id."
        );

        return Response.json(
            {
                success: false,
                version: WORKER_VERSION,
                webhook: "razorpay",
                event,
                error:
                    "Missing Razorpay order_id."
            },
            {
                status: 400
            }
        );
    }

    const member =
        await getMemberForRazorpayOrder(
            env.SOURCE_DB,
            orderId
        );

    if (!member) {
        console.log(
            "Razorpay webhook member not found.",
            {
                order_id: orderId
            }
        );

        return Response.json({
            success: true,
            version: WORKER_VERSION,
            webhook: "razorpay",
            event,
            order_id: orderId,
            member_found: false
        });
    }

    const payment =
        await getPaymentOrderForRazorpayOrder(
            env.SOURCE_DB,
            orderId,
            member.id
        );

    if (!payment) {
        console.error(
            "Razorpay webhook payment order not found.",
            {
                order_id: orderId,
                member_id:
                    member.id
            }
        );

        return Response.json(
            {
                success: false,
                version: WORKER_VERSION,
                webhook: "razorpay",
                event,
                order_id: orderId,
                member_found: true,
                error:
                    "Matching payment order not found."
            },
            {
                status: 400
            }
        );
    }

    const paymentCapturedAt =
        resolveRazorpayPaymentCapturedAt(
            payment,
            payload
        );

    if (
        paymentCapturedAt ===
        null
    ) {
        console.error(
            "Razorpay webhook payment capture timestamp invalid.",
            {
                order_id: orderId,
                member_id:
                    member.id,
                payment_order_id:
                    payment.id
            }
        );

        return Response.json(
            {
                success: false,
                version: WORKER_VERSION,
                webhook: "razorpay",
                event,
                order_id: orderId,
                member_found: true,
                error:
                    "Invalid payment capture timestamp."
            },
            {
                status: 400
            }
        );
    }

    let saveResult;

    try {
        saveResult =
            await saveMemberFromPaymentOrder(
                env.CONTACTS_DB,
                member,
                payment,
                paymentCapturedAt
            );
    } catch (error) {
        if (
            isDuplicateMemberError(
                error
            )
        ) {
            console.log(
                "Razorpay webhook duplicate member ignored.",
                {
                    order_id: orderId,
                    payment_order_id:
                        payment.id,
                    member_id:
                        member.id
                }
            );

            return Response.json({
                success: true,
                version: WORKER_VERSION,
                webhook: "razorpay",
                event,
                order_id: orderId,
                payment_order_id:
                    payment.id,
                member_found: true,
                duplicate_member: true,
                google_contact_created: false
            });
        }

        throw error;
    }

    console.log(
        "Razorpay webhook saved member into contact sync database.",
        {
            order_id: orderId,
            payment_order_id:
                payment.id,
            member_id:
                member.id,
            inserted:
                saveResult.inserted,
            updated:
                saveResult.updated
        }
    );

    return Response.json({
        success: true,
        version: WORKER_VERSION,
        webhook: "razorpay",
        event,
        order_id: orderId,
        payment_order_id:
            payment.id,
        member_found: true,
        contact_sync_record_inserted:
            saveResult.inserted,
        contact_sync_record_updated:
            saveResult.updated,
        google_contact_created: false
    });
}

async function getMemberForRazorpayOrder(
    database,
    orderId
) {
    if (!hasValue(orderId)) {
        return null;
    }

    return database.prepare(
        `
        SELECT
            id,
            full_name,
            email,
            phone,
            activation_url
        FROM members
        WHERE activation_gateway_order_id = ?
        LIMIT 1
        `
    )
        .bind(
            orderId
        )
        .first();
}

async function getPaymentOrderForRazorpayOrder(
    database,
    orderId,
    memberId
) {
    if (!hasValue(orderId)) {
        return null;
    }

    return database.prepare(
        `
        SELECT
            id,
            member_id,
            payment_status,
            payment_captured_at
        FROM payment_orders
        WHERE gateway = 'razorpay'
          AND gateway_order_id = ?
          AND member_id = ?
        ORDER BY id DESC
        LIMIT 1
        `
    )
        .bind(
            orderId,
            memberId
        )
        .first();
}

function resolveRazorpayPaymentCapturedAt(
    payment,
    payload
) {
    const paymentCapturedAt =
        parseUnixTimestamp(
            payment
                ?.payment_captured_at
        );

    if (
        paymentCapturedAt !==
        null
    ) {
        return paymentCapturedAt;
    }

    return parseUnixTimestamp(
        payload
            ?.payload
            ?.payment
            ?.entity
            ?.created_at
    );
}

function isDuplicateMemberError(
    error
) {
    const message =
        getErrorMessage(
            error
        )
            .toLowerCase();

    return (
        message.includes(
            "unique"
        ) &&
        message.includes(
            "member"
        )
    );
}

async function verifyRazorpayWebhookSignature(
    rawBody,
    signature,
    secret
) {
    if (
        !hasValue(signature) ||
        !hasValue(secret)
    ) {
        return false;
    }

    const encoder =
        new TextEncoder();

    const key =
        await crypto.subtle.importKey(
            "raw",
            encoder.encode(secret),
            {
                name: "HMAC",
                hash: "SHA-256"
            },
            false,
            [
                "sign"
            ]
        );

    const digest =
        await crypto.subtle.sign(
            "HMAC",
            key,
            encoder.encode(
                rawBody
            )
        );

    return constantTimeStringEqual(
        signature.trim().toLowerCase(),
        arrayBufferToHex(digest)
    );
}

/*
===============================================================================
PART 2
MEMBERS TABLE INCREMENTAL SCANNER
===============================================================================
*/

async function syncMembersTable(env) {
    const config =
        getWorkerConfiguration(env);

    const syncState =
        await getSyncState(
            env.CONTACTS_DB
        );

    const lastMemberId =
        syncState.last_member_id ||
        0;

    console.log(
        "Members cursor:",
        lastMemberId
    );

    /*
    -----------------------------------------------------------------------
    Scan every new row.

    Even unpaid rows are scanned because the cursor represents the last
    inspected source row rather than the last copied paid member.
    -----------------------------------------------------------------------
    */

    const sourceResult =
        await env.SOURCE_DB.prepare(
            `
            SELECT
                id,
                full_name,
                email,
                phone,
                activation_url
            FROM members
            WHERE id > ?
            ORDER BY id ASC
            LIMIT ?
            `
        )
            .bind(
                lastMemberId,
                config.membersScanLimit
            )
            .all();

    const scannedRows =
        sourceResult.results ||
        [];

    if (
        scannedRows.length ===
        0
    ) {
        return {
            success: true,

            previous_last_member_id:
                lastMemberId,

            current_last_member_id:
                lastMemberId,

            rows_scanned: 0,

            eligible_rows: 0,

            inserted_rows: 0,

            existing_rows: 0,

            message:
                "No new members found."
        };
    }

    /*
    -----------------------------------------------------------------------
    Only paid members proceed.
    -----------------------------------------------------------------------
    */

    const eligibleRows =
        scannedRows.filter(
            member =>
                hasValue(
                    member.activation_url
                )
        );

    let insertedRows = 0;
    let existingRows = 0;

    for (
        const member
        of eligibleRows
    ) {
        const insertResult =
            await insertMemberIfMissing(
                env.CONTACTS_DB,
                member
            );

        if (
            insertResult.inserted
        ) {
            insertedRows++;
        } else {
            existingRows++;
        }
    }

    const newestScannedId =
        scannedRows[
            scannedRows.length -
            1
        ].id;

    await updateMembersSyncState(
        env.CONTACTS_DB,
        newestScannedId,
        scannedRows.length
    );

    return {
        success: true,

        previous_last_member_id:
            lastMemberId,

        current_last_member_id:
            newestScannedId,

        rows_scanned:
            scannedRows.length,

        eligible_rows:
            eligibleRows.length,

        inserted_rows:
            insertedRows,

        existing_rows:
            existingRows
    };
}

/*
===============================================================================
INSERT MEMBER
===============================================================================
*/

async function insertMemberIfMissing(
    database,
    member
) {
    /*
    INSERT OR IGNORE relies on the unique member_id index.
    */

    const result =
        await database.prepare(
            `
            INSERT OR IGNORE INTO
            member_contact_sync_records (
                member_id,
                full_name,
                email,
                phone,
                activation_url,
                source_members,
                source_payment_orders,
                google_contact_status,
                created_at,
                updated_at
            )
            VALUES (
                ?,
                ?,
                ?,
                ?,
                ?,
                1,
                0,
                'pending',
                CURRENT_TIMESTAMP,
                CURRENT_TIMESTAMP
            )
            `
        )
            .bind(
                member.id,

                normalizeRequiredText(
                    member.full_name,
                    "Unknown Member"
                ),

                normalizeNullableText(
                    member.email
                ),

                normalizeNullableText(
                    member.phone
                ),

                member.activation_url.trim()
            )
            .run();

    return {
        inserted:
            Number(
                result.meta
                    ?.changes ||
                0
            ) > 0
    };
}

/*
===============================================================================
UPDATE MEMBERS CURSOR
===============================================================================
*/

async function updateMembersSyncState(
    database,
    lastMemberId,
    scannedRows
) {
    await database.prepare(
        `
        UPDATE sync_state
        SET
            last_member_id = ?,

            total_members_scanned =
                total_members_scanned + ?,

            last_members_scan_at =
                CURRENT_TIMESTAMP,

            updated_at =
                CURRENT_TIMESTAMP

        WHERE id = 1
        `
    )
        .bind(
            lastMemberId,
            scannedRows
        )
        .run();
}

/*
===============================================================================
PART 3
PAYMENT ORDERS INCREMENTAL SCANNER
===============================================================================
*/

async function syncPaymentOrdersTable(
    env
) {
    const config =
        getWorkerConfiguration(env);

    const syncState =
        await getSyncState(
            env.CONTACTS_DB
        );

    const lastPaymentOrderId =
        syncState
            .last_payment_order_id ||
        0;

    const currentUnixTime =
        Math.floor(
            Date.now() /
            1000
        );

    const captureCutoffTime =
        currentUnixTime -
        (
            config
                .paymentCaptureLagMinutes *
            60
        );

    console.log(
        "Payment cursor:",
        lastPaymentOrderId
    );

    console.log(
        "Capture cutoff:",
        captureCutoffTime
    );

    const paymentResult =
        await env.SOURCE_DB.prepare(
            `
            SELECT
                id,
                member_id,
                payment_status,
                payment_captured_at
            FROM payment_orders
            WHERE id > ?
            ORDER BY id ASC
            LIMIT ?
            `
        )
            .bind(
                lastPaymentOrderId,
                config
                    .paymentOrderScanLimit
            )
            .all();

    const paymentOrders =
        paymentResult.results ||
        [];

    if (
        paymentOrders.length ===
        0
    ) {
        return {
            success: true,

            previous_last_payment_order_id:
                lastPaymentOrderId,

            current_last_payment_order_id:
                lastPaymentOrderId,

            rows_loaded: 0,

            rows_scanned: 0,

            captured_orders: 0,

            inserted_members: 0,

            updated_members: 0,

            message:
                "No new payment orders."
        };
    }

    let scannedRows = 0;
    let capturedOrders = 0;
    let insertedMembers = 0;
    let updatedMembers = 0;
    let skippedNonCaptured = 0;
    let blockedOrder = null;

    let newestProcessedOrderId =
        lastPaymentOrderId;

    for (
        const payment
        of paymentOrders
    ) {
        const paymentStatus =
            normalizeStatus(
                payment
                    .payment_status
            );

        /*
        ---------------------------------------------------------
        Ignore non captured orders.
        ---------------------------------------------------------
        */

        if (
            paymentStatus !==
            "captured"
        ) {
            skippedNonCaptured++;
            scannedRows++;

            newestProcessedOrderId =
                payment.id;

            continue;
        }

        const capturedAt =
            parseUnixTimestamp(
                payment
                    .payment_captured_at
            );

        /*
        ---------------------------------------------------------
        Invalid timestamp.
        ---------------------------------------------------------
        */

        if (
            capturedAt ===
            null
        ) {
            blockedOrder = {
                payment_order_id:
                    payment.id,

                reason:
                    "Invalid capture timestamp."
            };

            break;
        }

        /*
        ---------------------------------------------------------
        Wait for configurable lag.
        ---------------------------------------------------------
        */

        if (
            capturedAt >
            captureCutoffTime
        ) {
            blockedOrder = {
                payment_order_id:
                    payment.id,

                member_id:
                    payment.member_id,

                payment_captured_at:
                    capturedAt,

                reason:
                    "Capture lag not completed."
            };

            break;
        }

        /*
        ---------------------------------------------------------
        Fetch corresponding member.
        ---------------------------------------------------------
        */

        const member =
            await getMemberForPaymentOrder(
                env.SOURCE_DB,
                payment.member_id
            );

        if (!member) {
            blockedOrder = {
                payment_order_id:
                    payment.id,

                member_id:
                    payment.member_id,

                reason:
                    "Matching member not found."
            };

            break;
        }

        /*
        ---------------------------------------------------------
        Membership not updated yet.
        ---------------------------------------------------------
        */

        if (
            !hasValue(
                member
                    .activation_url
            )
        ) {
            blockedOrder = {
                payment_order_id:
                    payment.id,

                member_id:
                    payment.member_id,

                reason:
                    "activation_url missing."
            };

            break;
        }

        /*
        ---------------------------------------------------------
        Save into target database.
        ---------------------------------------------------------
        */

        const saveResult =
            await saveMemberFromPaymentOrder(
                env.CONTACTS_DB,
                member,
                payment,
                capturedAt
            );

        if (
            saveResult.inserted
        ) {
            insertedMembers++;
        } else {
            updatedMembers++;
        }

        capturedOrders++;
        scannedRows++;

        newestProcessedOrderId =
            payment.id;
    }

    if (
        scannedRows >
        0
    ) {
        await updatePaymentOrdersSyncState(
            env.CONTACTS_DB,
            newestProcessedOrderId,
            scannedRows
        );
    }

    return {
        success: true,

        previous_last_payment_order_id:
            lastPaymentOrderId,

        current_last_payment_order_id:
            newestProcessedOrderId,

        rows_loaded:
            paymentOrders.length,

        rows_scanned:
            scannedRows,

        captured_orders:
            capturedOrders,

        inserted_members:
            insertedMembers,

        updated_members:
            updatedMembers,

        skipped_non_captured:
            skippedNonCaptured,

        blocked_order:
            blockedOrder
    };
}

/*
===============================================================================
FETCH MEMBER
===============================================================================
*/

async function getMemberForPaymentOrder(
    database,
    memberId
) {
    if (
        memberId === null ||
        memberId === undefined ||
        String(
            memberId
        ).trim() === ""
    ) {
        return null;
    }

    return database.prepare(
        `
        SELECT
            id,
            full_name,
            email,
            phone,
            activation_url
        FROM members
        WHERE id = ?
        LIMIT 1
        `
    )
        .bind(memberId)
        .first();
}

/*
===============================================================================
INSERT OR UPDATE MEMBER FROM PAYMENT ORDER
===============================================================================
*/

async function saveMemberFromPaymentOrder(
    database,
    member,
    payment,
    paymentCapturedAt
) {
    const existing =
        await database.prepare(
            `
            SELECT id
            FROM member_contact_sync_records
            WHERE member_id = ?
            LIMIT 1
            `
        )
            .bind(
                member.id
            )
            .first();

    /*
    ---------------------------------------------------------
    Existing record.
    ---------------------------------------------------------
    */

    if (existing) {
        await database.prepare(
            `
            UPDATE member_contact_sync_records
            SET
                full_name = ?,
                email = ?,
                phone = ?,
                activation_url = ?,
                payment_order_id = ?,
                payment_captured_at = ?,
                source_payment_orders = 1,
                updated_at = CURRENT_TIMESTAMP,
                last_error = NULL
            WHERE member_id = ?
            `
        )
            .bind(
                normalizeRequiredText(
                    member.full_name,
                    "Unknown Member"
                ),

                normalizeNullableText(
                    member.email
                ),

                normalizeNullableText(
                    member.phone
                ),

                member
                    .activation_url
                    .trim(),

                payment.id,

                paymentCapturedAt,

                member.id
            )
            .run();

        return {
            inserted: false,
            updated: true
        };
    }

    /*
    ---------------------------------------------------------
    Older member newly becoming paid.
    ---------------------------------------------------------
    */

    await database.prepare(
        `
        INSERT INTO member_contact_sync_records (
            member_id,
            full_name,
            email,
            phone,
            activation_url,
            payment_order_id,
            payment_captured_at,
            source_members,
            source_payment_orders,
            google_contact_status,
            created_at,
            updated_at
        )
        VALUES (
