async function markGoogleContactSyncing(
    database,
    recordId
) {
    const result =
        await database.prepare(
            `
        UPDATE member_contact_sync_records
        SET
            google_contact_status = 'syncing',
            google_contact_last_error = NULL,
            updated_at = CURRENT_TIMESTAMP
        WHERE id = ?
        AND google_contact_status = 'pending'
        `
    )
        .bind(recordId)
        .run();

    return Number(
        result.meta
            ?.changes ||
        0
    ) === 1;
}

async function markGoogleContactSynced(
    database,
    recordId,
    googleContact,
    fallbackName
) {
    await database.prepare(
        `
        UPDATE member_contact_sync_records
        SET
            google_contact_id = ?,
            google_contact_name = ?,
            google_contact_status = 'synced',
            google_contact_synced_at = ?,
            google_contact_last_error = NULL,
            updated_at = CURRENT_TIMESTAMP
        WHERE id = ?
        `
    )
        .bind(
            googleContact
                .resourceName,

            extractGoogleContactName(
                googleContact,
                fallbackName
            ),

            Math.floor(
                Date.now() /
                1000
            ),

            recordId
        )
        .run();
}

async function markGoogleContactFailed(
    database,
    recordId,
    error
) {
    await database.prepare(
        `
        UPDATE member_contact_sync_records
        SET
            google_contact_status = 'failed',
            google_contact_last_error = ?,
            updated_at = CURRENT_TIMESTAMP
        WHERE id = ?
        `
    )
        .bind(
            truncateText(
                error,
                2000
            ),

            recordId
        )
        .run();
}

/*
===============================================================================
GOOGLE PERSON BUILDER
===============================================================================
*/

function buildGooglePerson(
    contact
) {
    const nameParts =
        splitContactName(
            normalizeRequiredText(
                contact.full_name,
                "Member"
            )
        );

    const person = {
        names: [
            {
                givenName:
                    nameParts
                        .givenName,

                familyName:
                    nameParts
                        .familyName
            }
        ],

        userDefined: [
            {
                key:
                    "KenFolios Member ID",

                value:
                    String(
                        contact.member_id
                    )
            },

            {
                key:
                    "KenFolios Sync Record ID",

                value:
                    String(
                        contact.id
                    )
            }
        ]
    };

    /*
    ---------------------------------------------------------------
    Email validation.
    ---------------------------------------------------------------
    */

    const email =
        normalizeNullableText(
            contact.email
        );

    if (
        email &&
        email.includes("@")
    ) {
        person.emailAddresses = [
            {
                value: email,
                type: "work"
            }
        ];
    }

    /*
    ---------------------------------------------------------------
    Phone validation.
    ---------------------------------------------------------------
    */

    const phone =
        normalizeNullableText(
            contact.phone
        );

    if (
        phone &&
        phone.length >=
        8
    ) {
        person.phoneNumbers = [
            {
                value: phone,
                type: "mobile"
            }
        ];
    }

    const activationUrl =
        normalizeNullableText(
            contact
                .activation_url
        );

    if (activationUrl) {
        person.urls = [
            {
                value:
                    activationUrl,

                type:
                    "profile"
            }
        ];
    }

    return person;
}

/*
===============================================================================
PART 5
GOOGLE OAUTH + GOOGLE PEOPLE API
===============================================================================
*/

async function getGoogleAccessToken(
    env
) {
    const body =
        new URLSearchParams();

    body.set(
        "client_id",
        env.GOOGLE_CLIENT_ID
    );

    body.set(
        "client_secret",
        env.GOOGLE_CLIENT_SECRET
    );

    body.set(
        "refresh_token",
        env.GOOGLE_REFRESH_TOKEN
    );

    body.set(
        "grant_type",
        "refresh_token"
    );

    const controller =
        new AbortController();

    const timeout =
        setTimeout(
            () =>
                controller.abort(),

            GOOGLE_API_TIMEOUT_MS
        );

    let response;

    try {
        response =
            await fetch(
                "https://oauth2.googleapis.com/token",

                {
                    method: "POST",

                    headers: {
                        "Content-Type":
                            "application/x-www-form-urlencoded"
                    },

                    body:
                        body.toString(),

                    signal:
                        controller.signal
                }
            );
    } finally {
        clearTimeout(
            timeout
        );
    }

    const responseText =
        await response.text();

    const json =
        safelyParseJson(
            responseText
        );

    if (
        !response.ok ||
        !json ||
        !json.access_token
    ) {
        throw new Error(
            formatGoogleApiError(
                response.status,
                json,
                responseText,
                "Unable to obtain Google OAuth access token"
            )
        );
    }

    return json.access_token;
}

/*
===============================================================================
CREATE GOOGLE CONTACT
===============================================================================
*/

async function createGoogleContact(
    accessToken,
    contact,
    timeoutMs
) {
    const person =
        buildGooglePerson(
            contact
        );

    const personFields = [
        "names",
        "emailAddresses",
        "phoneNumbers",
        "urls",
        "userDefined"
    ].join(",");

    const controller =
        new AbortController();

    const timeout =
        setTimeout(
            () =>
                controller.abort(),

            timeoutMs
        );

    let response;

    try {
        response =
            await fetch(
                "https://people.googleapis.com/v1/people:createContact" +
                "?personFields=" +
                encodeURIComponent(
                    personFields
                ),

                {
                    method: "POST",

                    headers: {
                        Authorization:
                            "Bearer " +
                            accessToken,

                        "Content-Type":
                            "application/json"
                    },

                    body:
                        JSON.stringify(
                            person
                        ),

                    signal:
                        controller.signal
                }
            );
    } finally {
        clearTimeout(
            timeout
        );
    }

    const responseText =
        await response.text();

    const json =
        safelyParseJson(
            responseText
        );

    if (
        !response.ok ||
        !json ||
        !json.resourceName
    ) {
        throw new Error(
            formatGoogleApiError(
                response.status,
                json,
                responseText,
                "Google contact creation failed"
            )
        );
    }

    return json;
}

/*
===============================================================================
GOOGLE CONTACT NAME
===============================================================================
*/

function extractGoogleContactName(
    googleContact,
    fallbackName
) {
    if (
        googleContact &&
        Array.isArray(
            googleContact.names
        )
    ) {
        for (
            const name
            of googleContact.names
        ) {
            if (
                hasValue(
                    name.displayName
                )
            ) {
                return name
                    .displayName
                    .trim();
            }
        }
    }

    return normalizeRequiredText(
        fallbackName,
        "Unknown"
    );
}

/*
===============================================================================
SPLIT NAME
===============================================================================
*/

function splitContactName(
    fullName
) {
    const parts =
        String(fullName)
            .trim()
            .split(/\s+/)
            .filter(Boolean);

    if (
        parts.length ===
        0
    ) {
        return {
            givenName:
                "Member",

            familyName:
                ""
        };
    }

    if (
        parts.length ===
        1
    ) {
        return {
            givenName:
                parts[0],

            familyName:
                ""
        };
    }

    return {
        givenName:
            parts
                .slice(
                    0,
                    -1
                )
                .join(" "),

        familyName:
            parts[
                parts.length -
                1
            ]
    };
}

/*
===============================================================================
GOOGLE ENVIRONMENT VALIDATION
===============================================================================
*/

function validateGoogleEnvironment(
    env
) {
    const missing = [];

    if (
        !hasValue(
            env.GOOGLE_CLIENT_ID
        )
    ) {
        missing.push(
            "GOOGLE_CLIENT_ID"
        );
    }

    if (
        !hasValue(
            env.GOOGLE_CLIENT_SECRET
        )
    ) {
        missing.push(
            "GOOGLE_CLIENT_SECRET"
        );
    }

    if (
        !hasValue(
            env.GOOGLE_REFRESH_TOKEN
        )
    ) {
        missing.push(
            "GOOGLE_REFRESH_TOKEN"
        );
    }

    if (
        missing.length
    ) {
        throw new Error(
            "Missing Google variables: " +
            missing.join(", ")
        );
    }
}

