            ?,
            ?,
            ?,
            ?,
            ?,
            ?,
            0,
            1,
            'pending',
            CURRENT_TIMESTAMP,
            CURRENT_TIMESTAMP
        )
        `
    )
        .bind(
            member.id,

            normalizeRequiredText(
                member.full_name,
                "Unknown Member"
            ),

            normalizeNullableText(
                member.email
            ),

            normalizeNullableText(
                member.phone
            ),

            member
                .activation_url
                .trim(),

            payment.id,

            paymentCapturedAt
        )
        .run();

    return {
        inserted: true,
        updated: false
    };
}

