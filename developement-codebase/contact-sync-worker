async function processPaymentOrder(env, paymentOrder) {

  if (!isCapturedPayment(paymentOrder)) {
    return false;
  }

  const member = await getMemberById(
    env,
    paymentOrder.member_id
  );

  if (!member) {
    console.log(
      "Member not found:",
      paymentOrder.member_id
    );
    return false;
  }

  member.payment_order_id = paymentOrder.id;
  member.payment_captured_at = paymentOrder.payment_captured_at;
  member.source_payment_orders = 1;

  await upsertContact(env, member);

  return true;

