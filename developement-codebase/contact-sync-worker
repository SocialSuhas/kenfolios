function sanitizeEmail(email) {

  if (!email) return null;

  email = email.trim().toLowerCase();

  if (email === "") return null;

  return email;

}

function sanitizePhone(phone) {

  if (!phone) return null;

  phone = phone.replace(/\D/g, "");

  if (phone.startsWith("91") && phone.length === 12) {
    return "+" + phone;
  }

  if (phone.length === 10) {
    return "+91" + phone;
  }

  return "+" + phone;

}

function normalizeMember(member) {

  return {

    id: member.id,

    payment_order_id:
      member.payment_order_id ?? null,

    full_name:
      member.full_name?.trim(),

    email:
      sanitizeEmail(member.email),

    phone:
      sanitizePhone(member.phone),

    activation_url:
      member.activation_url,

    payment_captured_at:
      member.payment_captured_at ??
      member.activation_captured_at,

    source_members:
      member.source_members ?? 1,

    source_payment_orders:
      member.source_payment_orders ?? 0

  };

}

