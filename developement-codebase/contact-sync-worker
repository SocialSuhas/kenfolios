async function upsertContact(env, member) {

  const now = Math.floor(Date.now() / 1000);

  // Find by member_id
  const existingMember = await env.CONTACTS_DB
    .prepare(`
      SELECT id
      FROM contacts
      WHERE member_id = ?
      LIMIT 1
    `)
    .bind(member.id)
    .first();

  if (existingMember) {

    await env.CONTACTS_DB
      .prepare(`
        UPDATE contacts
        SET
          full_name = ?,
          email = ?,
          phone = ?,
          activation_url = ?,
          source_members = 1,
          payment_captured_at = ?,
          updated_at = ?
        WHERE member_id = ?
      `)
      .bind(
        member.full_name,
        member.email,
        member.phone,
        member.activation_url,
        member.activation_captured_at,
        now,
        member.id
      )
      .run();

    console.log("Updated Member:", member.id);

    return;
  }

  // Find by email
  if (member.email) {

    const existingEmail = await env.CONTACTS_DB
      .prepare(`
        SELECT id
        FROM contacts
        WHERE email = ?
        LIMIT 1
      `)
      .bind(member.email)
      .first();

    if (existingEmail) {

      await env.CONTACTS_DB
        .prepare(`
          UPDATE contacts
          SET
            member_id = ?,
            full_name = ?,
            phone = ?,
            activation_url = ?,
            source_members = 1,
            payment_captured_at = ?,
            updated_at = ?
          WHERE email = ?
        `)
        .bind(
          member.id,
          member.full_name,
          member.phone,
          member.activation_url,
          member.activation_captured_at,
          now,
          member.email
        )
        .run();

      console.log("Updated Email:", member.email);

      return;
    }

  }

  // Insert
  await env.CONTACTS_DB
    .prepare(`
      INSERT INTO contacts (
        member_id,
        payment_order_id,
        full_name,
        email,
        phone,
        activation_url,
        source_members,
        source_payment_orders,
        payment_captured_at,
        created_at,
        updated_at
      )
      VALUES (?, NULL, ?, ?, ?, ?, 1, 0, ?, ?, ?)
    `)
    .bind(
      member.id,
      member.full_name,
      member.email,
      member.phone,
      member.activation_url,
      member.activation_captured_at,
      now,
      now
    )
    .run();

  console.log("Inserted:", member.id);

}

