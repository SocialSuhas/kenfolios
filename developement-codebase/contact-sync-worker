async function upsertContact(env, member) {

  const now = Math.floor(Date.now() / 1000);

  const sourceMembers = member.source_members ?? 1;
  const sourcePaymentOrders = member.source_payment_orders ?? 0;

  // Find by member_id
  const existingMember = await env.CONTACTS_DB
    .prepare(`
      SELECT *
      FROM contacts
      WHERE member_id = ?
      LIMIT 1
    `)
    .bind(member.id)
    .first();

  if (existingMember) {

    await env.CONTACTS_DB
      .prepare(`
        UPDATE contacts
        SET
          payment_order_id = COALESCE(?, payment_order_id),
          full_name = ?,
          email = ?,
          phone = ?,
          activation_url = ?,

          source_members = MAX(source_members, ?),
          source_payment_orders = MAX(source_payment_orders, ?),

          payment_captured_at = COALESCE(?, payment_captured_at),

          updated_at = ?

        WHERE member_id = ?
      `)
      .bind(
        member.payment_order_id ?? null,
        member.full_name,
        member.email,
        member.phone,
        member.activation_url,

        sourceMembers,
        sourcePaymentOrders,

        member.payment_captured_at ?? null,

        now,
        member.id
      )
      .run();

    return;
  }

  // Find by email
  if (member.email) {

    const existingEmail = await env.CONTACTS_DB
      .prepare(`
        SELECT *
        FROM contacts
        WHERE email = ?
        LIMIT 1
      `)
      .bind(member.email)
      .first();

    if (existingEmail) {

      await env.CONTACTS_DB
        .prepare(`
          UPDATE contacts
          SET
            member_id = ?,
            payment_order_id = COALESCE(?, payment_order_id),

            full_name = ?,
            phone = ?,
            activation_url = ?,

            source_members = MAX(source_members, ?),
            source_payment_orders = MAX(source_payment_orders, ?),

            payment_captured_at = COALESCE(?, payment_captured_at),

            updated_at = ?

          WHERE email = ?
        `)
        .bind(
          member.id,
          member.payment_order_id ?? null,

          member.full_name,
          member.phone,
          member.activation_url,

          sourceMembers,
          sourcePaymentOrders,

          member.payment_captured_at ?? null,

          now,
          member.email
        )
        .run();

      return;
    }

  }

  // Insert new contact
  await env.CONTACTS_DB
    .prepare(`
      INSERT INTO contacts (
        member_id,
        payment_order_id,

        full_name,
        email,
        phone,
        activation_url,

        source_members,
        source_payment_orders,

        payment_captured_at,

        created_at,
        updated_at

      )
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
    `)
    .bind(
      member.id,
      member.payment_order_id ?? null,

      member.full_name,
      member.email,
      member.phone,
      member.activation_url,

      sourceMembers,
      sourcePaymentOrders,

      member.payment_captured_at ?? null,

      now,
      now
    )
    .run();

}
