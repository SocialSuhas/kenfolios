async function runMembersSync(env, syncState) {

  const members = await getMembersBatch(
    env,
    syncState.last_members_id
  );

  stats.membersScanned = members.length;

  let lastProcessedMember = null;

  for (const member of members) {

    lastProcessedMember = member;

    if (!isPaidMember(member)) {
      continue;
    }

    stats.paidMembers++;

    await upsertContact(
      env,
      member
    );

  }

  await updateMembersSyncState(
    env,
    lastProcessedMember
  );

  return {
    members,
    lastProcessedMember
  };

}

async function runPaymentOrdersSync(env, syncState) {

  const paymentOrders = await getPaymentOrdersBatch(
    env,
    syncState.last_payment_orders_id
  );

  stats.paymentOrdersScanned = paymentOrders.length;

  let lastProcessedPaymentOrder = null;

  for (const paymentOrder of paymentOrders) {

    lastProcessedPaymentOrder = paymentOrder;

    const processed = await processPaymentOrder(
      env,
      paymentOrder
    );

    if (processed) {
      stats.capturedPayments++;
    }

  }

  await updatePaymentOrdersSyncState(
    env,
    lastProcessedPaymentOrder
  );

  return {
    paymentOrders,
    lastProcessedPaymentOrder
  };

