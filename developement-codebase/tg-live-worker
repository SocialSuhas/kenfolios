/* ------------------------------------------------------------
   Post Reminder
------------------------------------------------------------ */

async function postReminder(env) {

  /*
   * Determine the next template
   * using D1 history.
   */

  const template =

    await getNextTemplate(env);

  if (!template) {

    console.log(

      "No reminder template available."

    );

    return;

  }

  /*
   * Post reminder.
   */

  const response =

    await sendMessage(

      env.TELEGRAM_LIVE_CHAT_ID,

      template.message,

      env

    );

  /*
   * Telegram API failed.
   */

  if (!response?.ok) {

    console.error(

      "Unable to post reminder.",

      response

    );

    return;

  }

  /*
   * Store reminder history.
   */

  await logTemplateUsage(

    {

      templateId:
        template.id,

      telegramMessageId:
        response.result.message_id,

      workerExecutionId:
        crypto.randomUUID()

    },

    env

  );

}


/* ============================================================
   D1 TEMPLATE SCHEDULER
============================================================ */


/* ------------------------------------------------------------
   Get Next Eligible Template
------------------------------------------------------------ */

async function getNextTemplate(env) {

  /*
   * Safety check.
   */

  if (

    REMINDER_TEMPLATES.length === 0

  ) {

    return null;

  }

  /*
   * Read the most recently
   * posted template.
   */

  const lastPost =

    await env.LIVE_DB

      .prepare(

        `

        SELECT

          template_id

        FROM

          template_post_log

        ORDER BY

          id DESC

        LIMIT 1

        `

      )

      .first();

  /*
   * Read recent history.
   */

  const history =

    await env.LIVE_DB

      .prepare(

        `

        SELECT

          template_id

        FROM

          template_post_log

        ORDER BY

          id DESC

        LIMIT ?

        `

      )

      .bind(

        TEMPLATE_REUSE_GAP

      )

      .all();

  const recentlyUsed =

    new Set(

      (history.results || [])

      .map(

        row => row.template_id

      )

    );

  /*
   * Determine where to
   * begin searching.
   */

  let startTemplate = 1;

  if (lastPost) {

    startTemplate =

      lastPost.template_id + 1;

    if (

      startTemplate >

      TOTAL_TEMPLATES

    ) {

      startTemplate = 1;

    }

  }

  /*
   * Find the first template
   * that has not appeared in
   * the previous
   * TEMPLATE_REUSE_GAP posts.
   */

  for (

    let offset = 0;

    offset < TOTAL_TEMPLATES;

    offset++

  ) {

    const candidate =

      (

        (
          startTemplate - 1 + offset
        )

        %

        TOTAL_TEMPLATES

      )

      + 1;

    if (

      !recentlyUsed.has(candidate)

    ) {

      return {

        id:
          candidate,

        message:
          REMINDER_TEMPLATES[
            candidate - 1
          ]

      };

    }

  }

  /*
   * Safety fallback.
   */

  return {

    id:
      startTemplate,

    message:
      REMINDER_TEMPLATES[
        startTemplate - 1
      ]

  };

}


