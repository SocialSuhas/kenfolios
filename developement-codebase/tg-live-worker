/* ------------------------------------------------------------
   Live Group Permissions
------------------------------------------------------------ */

async function setLivePermissions(env, allow) {

  await fetch(
    `https://api.telegram.org/bot${env.TELEGRAM_BOT_TOKEN}/setChatPermissions`,
    {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({

        chat_id: env.TELEGRAM_LIVE_CHAT_ID,

        permissions: {

          can_send_messages: allow,
          can_send_media_messages: allow,
          can_send_polls: allow,
          can_send_other_messages: allow,
          can_add_web_page_previews: allow

        }

      })
    }
  );

}


/* ============================================================
   JOIN REQUEST HANDLING
============================================================ */


/* ------------------------------------------------------------
   Handle Join Request
------------------------------------------------------------ */

async function handleJoinRequest(joinRequest, env) {

  // Ignore requests for other groups.
  if (
    joinRequest.chat.id !== Number(env.TELEGRAM_LIVE_CHAT_ID)
  ) {
    return;
  }

  const isEligible = await isUserInAnnouncement(
    joinRequest.from.id,
    env
  );

  if (!isEligible) {
    return;
  }

  await fetch(
    `https://api.telegram.org/bot${env.TELEGRAM_BOT_TOKEN}/approveChatJoinRequest`,
    {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({

        chat_id: joinRequest.chat.id,
        user_id: joinRequest.from.id

      })
    }
  );

}


/* ============================================================
   MEMBER MONITORING
============================================================ */


/* ------------------------------------------------------------
   Verify Members
------------------------------------------------------------ */

async function handleChatMember(chatMember, env) {

  if (
    chatMember.chat.id !== Number(env.TELEGRAM_LIVE_CHAT_ID)
  ) {
    return;
  }

  if (
    chatMember.new_chat_member.status !== "member"
  ) {
    return;
  }

  const isEligible = await isUserInAnnouncement(
    chatMember.new_chat_member.user.id,
    env
  );

  if (isEligible) {
    return;
  }

  await fetch(
    `https://api.telegram.org/bot${env.TELEGRAM_BOT_TOKEN}/banChatMember`,
    {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({

        chat_id: chatMember.chat.id,
        user_id: chatMember.new_chat_member.user.id,

        // Temporary ban (60 seconds)
        until_date: Math.floor(Date.now() / 1000) + 60

      })
    }
  );

}


/* ============================================================
   ANNOUNCEMENT GROUP VERIFICATION
============================================================ */


/* ------------------------------------------------------------
   Check Announcement Group Membership
------------------------------------------------------------ */

async function isUserInAnnouncement(userId, env) {

  const response = await fetch(
    `https://api.telegram.org/bot${env.TELEGRAM_BOT_TOKEN}/getChatMember`,
    {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({

        chat_id: env.TELEGRAM_ANNOUNCEMENT_CHAT_ID,
        user_id: userId

      })
    }
  );

  const data = await response.json().catch(() => null);

  if (!data?.ok) {
    return false;
  }

  const status = data.result?.status;

  return (
    status === "creator" ||
    status === "administrator" ||
    status === "member"
  );

}


