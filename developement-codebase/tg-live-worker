/* ============================================================
   WORKER ENTRY POINT
============================================================ */

export default {

  /* ----------------------------------------------------------
     Telegram Webhook
  ---------------------------------------------------------- */

  async fetch(request, env) {

    if (request.method !== "POST") {
      return new Response("OK");
    }

    const update =
      await request.json().catch(() => null);

    if (!update) {
      return new Response("OK");
    }

    /*
     * Join Requests
     */

    if (update.chat_join_request) {

      await handleJoinRequest(

        update.chat_join_request,

        env

      );

    }

    /*
     * Member Updates
     */

    if (update.chat_member) {

      await handleChatMember(

        update.chat_member,

        env

      );

    }

    return new Response("OK");

  },


  /* ----------------------------------------------------------
     Scheduled Event
  ---------------------------------------------------------- */

  async scheduled(event, env, ctx) {

    /*
     * Executes once every
     * 15 minutes.
     */

    ctx.waitUntil(

      postReminder(env)

    );

  }

};


/* ============================================================
   JOIN REQUEST APPROVAL
============================================================ */


/* ------------------------------------------------------------
   Handle Join Requests
------------------------------------------------------------ */

async function handleJoinRequest(

  joinRequest,

  env

) {

  /*
   * Ignore requests for
   * other groups.
   */

  if (

    joinRequest.chat.id !==

    Number(env.TELEGRAM_LIVE_CHAT_ID)

  ) {

    return;

  }

  /*
   * Verify membership.
   */

  const isEligible =

    await isUserInAnnouncement(

      joinRequest.from.id,

      env

    );

  if (!isEligible) {

    return;

  }

  /*
   * Approve request.
   */

  await telegramApi(

    "approveChatJoinRequest",

    {

      chat_id:
        joinRequest.chat.id,

      user_id:
        joinRequest.from.id

    },

    env

  );

}


/* ------------------------------------------------------------
   Monitor Live Group Membership
------------------------------------------------------------ */

async function handleChatMember(

  chatMember,

  env

) {

  /*
   * Ignore updates from
   * other groups.
   */

  if (

    chatMember.chat.id !==

    Number(env.TELEGRAM_LIVE_CHAT_ID)

  ) {

    return;

  }

  /*
   * Only evaluate active
   * members.
   */

  if (

    chatMember
      .new_chat_member
      .status !== "member"

  ) {

    return;

  }

  const isEligible =

    await isUserInAnnouncement(

      chatMember
        .new_chat_member
        .user.id,

      env

    );

  if (isEligible) {

    return;

  }

  /*
   * Remove member.
   */

  await telegramApi(

    "banChatMember",

    {

      chat_id:
        chatMember.chat.id,

      user_id:
        chatMember
          .new_chat_member
          .user.id,

      until_date:

        Math.floor(

          Date.now() / 1000

        ) + 60

    },

    env

  );

}


/* ------------------------------------------------------------
   Verify Announcement
   Group Membership
------------------------------------------------------------ */

async function isUserInAnnouncement(

  userId,

  env

) {

  const response =

    await telegramApi(

      "getChatMember",

      {

        chat_id:
          env.TELEGRAM_ANNOUNCEMENT_CHAT_ID,

        user_id:
          userId

      },

      env

    );

  if (!response?.ok) {

    return false;

  }

  const status =

    response.result?.status;

  return (

    status === "creator" ||

    status === "administrator" ||

    status === "member"

  );

}


