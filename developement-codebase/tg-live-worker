/**
 * ============================================================
 * KENFOLIOS 24×7 LIVE INTERACTION GROUP WORKER
 * ============================================================
 *
 * This Cloudflare Worker manages the KenFolios
 * 24×7 Live Interaction Group on Telegram.
 *
 * Features
 * --------
 *
 * • Approves join requests only for members of the
 *   Announcement Group.
 *
 * • Automatically removes members who are no longer
 *   part of the Announcement Group.
 *
 * • Posts one randomly selected community reminder
 *   every 15 minutes.
 *
 * • Uses a growing reminder library
 *   (96 templates initially).
 *
 * Cloudflare Cron
 * ---------------
 *
 * Configure ONE Cron Trigger in Cloudflare
 * to run every 15 minutes.
 *
 * Environment Variables
 * ---------------------
 *
 * TELEGRAM_BOT_TOKEN
 * TELEGRAM_LIVE_CHAT_ID
 * TELEGRAM_ANNOUNCEMENT_CHAT_ID
 *
 * ============================================================
 */


/* ============================================================
   CONFIGURATION
============================================================ */


/* ------------------------------------------------------------
   Telegram Groups
------------------------------------------------------------ */

const LIVE_JOIN_LINK =
  "https://t.me/+WVY6y9gGEZhlYjhl";


/* ------------------------------------------------------------
   Reminder Schedule
------------------------------------------------------------ */

const REMINDER_INTERVAL_MINUTES = 15;


/* ============================================================
   WORKER ENTRY POINT
============================================================ */

export default {

  /* ----------------------------------------------------------
     Telegram Webhook
  ---------------------------------------------------------- */

  async fetch(request, env) {

    // Telegram sends webhook updates via POST.
    if (request.method !== "POST") {
      return new Response("OK");
    }

    const update = await request.json().catch(() => null);

    if (!update) {
      return new Response("OK");
    }

    /* ------------------------------------------------------
       Join Requests
    ------------------------------------------------------ */

    if (update.chat_join_request) {

      await handleJoinRequest(

        update.chat_join_request,
        env

      );

    }


    /* ------------------------------------------------------
       Member Updates
    ------------------------------------------------------ */

    if (update.chat_member) {

      await handleChatMember(

        update.chat_member,
        env

      );

    }

    return new Response("OK");

  },


  /* ----------------------------------------------------------
     Cloudflare Scheduled Event
  ---------------------------------------------------------- */

  async scheduled(event, env, ctx) {

    /*
     * This worker is scheduled to run
     * every 15 minutes.
     *
     * Each execution posts one randomly
     * selected community reminder.
     */

    ctx.waitUntil(

      postReminder(env)

    );

  }

};


/* ============================================================
   END OF PART 1
============================================================ */
/* ============================================================
   TELEGRAM MEMBERSHIP MANAGEMENT
============================================================ */


/* ------------------------------------------------------------
   Handle Join Requests
------------------------------------------------------------ */

async function handleJoinRequest(joinRequest, env) {

  // Ignore requests for other groups.
  if (
    joinRequest.chat.id !==
    Number(env.TELEGRAM_LIVE_CHAT_ID)
  ) {
    return;
  }

  // Only Announcement Group members are eligible.
  const isEligible = await isUserInAnnouncement(

    joinRequest.from.id,
    env

  );

  if (!isEligible) {
    return;
  }

  // Approve the join request.
  await telegramApi(

    "approveChatJoinRequest",

    {
      chat_id: joinRequest.chat.id,
      user_id: joinRequest.from.id
    },

    env

  );

}


/* ------------------------------------------------------------
   Monitor Live Group Membership
------------------------------------------------------------ */

async function handleChatMember(chatMember, env) {

  // Ignore updates from other groups.
  if (
    chatMember.chat.id !==
    Number(env.TELEGRAM_LIVE_CHAT_ID)
  ) {
    return;
  }

  /*
   * Only evaluate members who are currently
   * part of the Live Interaction Group.
   */

  if (
    chatMember.new_chat_member.status !== "member"
  ) {
    return;
  }

  const isEligible = await isUserInAnnouncement(

    chatMember.new_chat_member.user.id,
    env

  );

  if (isEligible) {
    return;
  }

  /*
   * Member is no longer in the
   * Announcement Group.
   *
   * Remove them from the Live Group.
   */

  await telegramApi(

    "banChatMember",

    {
      chat_id: chatMember.chat.id,

      user_id:
        chatMember.new_chat_member.user.id,

      // Temporary ban (60 seconds).
      until_date:
        Math.floor(Date.now() / 1000) + 60

    },

    env

  );

}


/* ------------------------------------------------------------
   Verify Announcement Group Membership
------------------------------------------------------------ */

async function isUserInAnnouncement(userId, env) {

  const response = await telegramApi(

    "getChatMember",

    {
      chat_id:
        env.TELEGRAM_ANNOUNCEMENT_CHAT_ID,

      user_id: userId
    },

    env

  );

  if (!response?.ok) {
    return false;
  }

  const status = response.result?.status;

  return (

    status === "creator" ||

    status === "administrator" ||

    status === "member"

  );

}


/* ============================================================
   END OF PART 2
============================================================ */
/* ============================================================
   TELEGRAM UTILITIES
============================================================ */


/* ------------------------------------------------------------
   Send Telegram Message
------------------------------------------------------------ */

async function sendMessage(chatId, text, env) {

  return telegramApi(

    "sendMessage",

    {
      chat_id: chatId,

      text: text,

      disable_web_page_preview: true
    },

    env

  );

}


/* ------------------------------------------------------------
   Telegram API Helper
------------------------------------------------------------ */

async function telegramApi(method, payload, env) {

  try {

    const response = await fetch(

      `https://api.telegram.org/bot${env.TELEGRAM_BOT_TOKEN}/${method}`,

      {
        method: "POST",

        headers: {
          "Content-Type": "application/json"
        },

        body: JSON.stringify(payload)

      }

    );

    return await response.json();

  }

  catch (error) {

    console.error(

      `Telegram API Error (${method})`,

      error

    );

    return null;

  }

}


/* ============================================================
   END OF PART 3
============================================================ */
/* ============================================================
   REMINDER ENGINE
============================================================ */


/* ------------------------------------------------------------
   Previous Template
------------------------------------------------------------ */

let previousTemplateIndex = -1;


/* ------------------------------------------------------------
   Post Community Reminder
------------------------------------------------------------ */

async function postReminder(env) {

  const message = getRandomTemplate();

  if (!message) {
    return;
  }

  await sendMessage(

    env.TELEGRAM_LIVE_CHAT_ID,

    message,

    env

  );

}


/* ------------------------------------------------------------
   Get Random Reminder Template
------------------------------------------------------------ */

function getRandomTemplate() {

  // No templates available.
  if (REMINDER_TEMPLATES.length === 0) {
    return null;
  }

  // Only one template.
  if (REMINDER_TEMPLATES.length === 1) {
    return REMINDER_TEMPLATES[0];
  }

  let randomIndex;

  /*
   * Avoid repeating
   * the previous template.
   */

  do {

    randomIndex = Math.floor(

      Math.random() *
      REMINDER_TEMPLATES.length

    );

  }

  while (
    randomIndex === previousTemplateIndex
  );

  previousTemplateIndex = randomIndex;

  return REMINDER_TEMPLATES[randomIndex];

}


