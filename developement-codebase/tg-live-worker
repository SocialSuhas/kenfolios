============================================================ */


/*
|--------------------------------------------------------------------------
| Current Logic
|--------------------------------------------------------------------------
|
| Randomly selects one reminder template.
|
| Immediate repetition is avoided.
|
| In a future version we can extend this to remember recently
| posted templates using KV or D1 without changing the rest
| of the worker.
|
*/

let lastTemplateIndex = -1;


/* ------------------------------------------------------------
   Get Random Template
------------------------------------------------------------ */

function getRandomTemplate() {

  if (REMINDER_TEMPLATES.length === 0) {
    return null;
  }

  if (REMINDER_TEMPLATES.length === 1) {
    return REMINDER_TEMPLATES[0];
  }

  let randomIndex;

  do {

    randomIndex = Math.floor(
      Math.random() * REMINDER_TEMPLATES.length
    );

  } while (randomIndex === lastTemplateIndex);

  lastTemplateIndex = randomIndex;

  return REMINDER_TEMPLATES[randomIndex];

}


