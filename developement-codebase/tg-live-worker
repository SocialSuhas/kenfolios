/* ============================================================
   TELEGRAM UTILITIES
============================================================ */


/* ------------------------------------------------------------
   Set Live Group Permissions
------------------------------------------------------------ */

async function setLivePermissions(env, allow) {

  await telegramApi(

    "setChatPermissions",

    {
      chat_id: env.TELEGRAM_LIVE_CHAT_ID,

      permissions: {

        can_send_messages: allow,
        can_send_media_messages: allow,
        can_send_polls: allow,
        can_send_other_messages: allow,
        can_add_web_page_previews: allow

      }

    },

    env

  );

}


/* ------------------------------------------------------------
   Send Telegram Message
------------------------------------------------------------ */

async function sendMessage(chatId, text, env) {

  return telegramApi(

    "sendMessage",

    {
      chat_id: chatId,
      text: text,
      disable_web_page_preview: true
    },

    env

  );

}


/* ------------------------------------------------------------
   Telegram API Helper
------------------------------------------------------------ */

async function telegramApi(method, payload, env) {

  try {

    const response = await fetch(

      `https://api.telegram.org/bot${env.TELEGRAM_BOT_TOKEN}/${method}`,

      {
        method: "POST",

        headers: {
          "Content-Type": "application/json"
        },

        body: JSON.stringify(payload)

      }

    );

    return await response.json();

  } catch (error) {

    console.error(

      `Telegram API Error (${method})`,

      error

    );

    return null;

  }

}


