/**
 * ============================================================
 * KENFOLIOS LIVE INTERACTION GROUP WORKER
 * ============================================================
 *
 * This Cloudflare Worker manages the KenFolios Live
 * Interaction Group on Telegram.
 *
 * Features
 * --------
 * • Approves join requests only for members of the
 *   Announcement Group.
 *
 * • Removes members who are no longer part of the
 *   Announcement Group.
 *
 * • Opens the Live Interaction Group every day at
 *   9:00 AM IST.
 *
 * • Closes the Live Interaction Group every day at
 *   9:00 PM IST.
 *
 * • Posts one randomly selected community reminder
 *   every 15 minutes while the group is open.
 *
 * Cloudflare Cron
 * ---------------
 * Configure ONE Cron Trigger to execute every
 * 15 minutes.
 *
 * Environment Variables
 * ---------------------
 * TELEGRAM_BOT_TOKEN
 * TELEGRAM_LIVE_CHAT_ID
 * TELEGRAM_ANNOUNCEMENT_CHAT_ID
 *
 * ============================================================
 */


/* ============================================================
   CONFIGURATION
============================================================ */


/* ------------------------------------------------------------
   Telegram Groups
------------------------------------------------------------ */

const LIVE_JOIN_LINK =
  "https://t.me/+WVY6y9gGEZhlYjhl";


/* ------------------------------------------------------------
   Live Interaction Window (IST)
------------------------------------------------------------ */

const LIVE_OPEN_HOUR = 9;
const LIVE_OPEN_MINUTE = 0;

const LIVE_CLOSE_HOUR = 21;
const LIVE_CLOSE_MINUTE = 0;


/* ------------------------------------------------------------
   Reminder Schedule
------------------------------------------------------------ */

const REMINDER_INTERVAL_MINUTES = 15;


/* ------------------------------------------------------------
   Time Zone
------------------------------------------------------------ */

const IST_OFFSET_MINUTES = 330;


/* ============================================================
   END OF PART 1
============================================================ */
/* ============================================================
   WORKER ENTRY POINT
============================================================ */

export default {

  /* ----------------------------------------------------------
     Telegram Webhook
  ---------------------------------------------------------- */

  async fetch(request, env) {

    // Telegram sends webhook updates via POST.
    if (request.method !== "POST") {
      return new Response("OK");
    }

    const update = await request.json().catch(() => null);

    if (!update) {
      return new Response("OK");
    }

    /* ------------------------------------------------------
       Join Request
    ------------------------------------------------------ */

    if (update.chat_join_request) {
      await handleJoinRequest(
        update.chat_join_request,
        env
      );
    }

    /* ------------------------------------------------------
       Member Updates
    ------------------------------------------------------ */

    if (update.chat_member) {
      await handleChatMember(
        update.chat_member,
        env
      );
    }

    return new Response("OK");

  },


  /* ----------------------------------------------------------
     Cloudflare Cron Trigger
  ---------------------------------------------------------- */

  async scheduled(event, env, ctx) {

    // Convert UTC to IST.
    const utcNow = new Date(event.scheduledTime);

    const istNow = new Date(
      utcNow.getTime() + (IST_OFFSET_MINUTES * 60 * 1000)
    );

    const hour = istNow.getHours();
    const minute = istNow.getMinutes();


    /* ------------------------------------------------------
       Open Live Interaction Group
       9:00 AM IST
    ------------------------------------------------------ */

    if (
      hour === LIVE_OPEN_HOUR &&
      minute === LIVE_OPEN_MINUTE
    ) {
      ctx.waitUntil(openLiveWindow(env));
      return;
    }


    /* ------------------------------------------------------
       Close Live Interaction Group
       9:00 PM IST
    ------------------------------------------------------ */

    if (
      hour === LIVE_CLOSE_HOUR &&
      minute === LIVE_CLOSE_MINUTE
    ) {
      ctx.waitUntil(closeLiveWindow(env));
      return;
    }


    /* ------------------------------------------------------
       Community Reminder
       Every 15 minutes between
       9:15 AM and 8:45 PM IST
    ------------------------------------------------------ */

    if (isReminderTime(hour, minute)) {
      ctx.waitUntil(postReminder(env));
      return;
    }


    /* ------------------------------------------------------
       Outside Live Interaction Window
    ------------------------------------------------------ */

    return;

  }

};


/* ============================================================
   END OF PART 2
============================================================ */
/* ============================================================
   TELEGRAM MEMBERSHIP MANAGEMENT
============================================================ */


/* ------------------------------------------------------------
   Handle Join Requests
------------------------------------------------------------ */

async function handleJoinRequest(joinRequest, env) {

  // Ignore requests for other groups.
  if (joinRequest.chat.id !== Number(env.TELEGRAM_LIVE_CHAT_ID)) {
    return;
  }

  // Only Announcement Group members are allowed.
  const isEligible = await isUserInAnnouncement(
    joinRequest.from.id,
    env
  );

  if (!isEligible) {
    return;
  }

  await telegramApi(

    "approveChatJoinRequest",

    {
      chat_id: joinRequest.chat.id,
      user_id: joinRequest.from.id
    },

    env

  );

}


/* ------------------------------------------------------------
   Monitor Live Group Membership
------------------------------------------------------------ */

async function handleChatMember(chatMember, env) {

  // Ignore updates from other groups.
  if (chatMember.chat.id !== Number(env.TELEGRAM_LIVE_CHAT_ID)) {
    return;
  }

  // Only check members who have joined.
  if (chatMember.new_chat_member.status !== "member") {
    return;
  }

  const isEligible = await isUserInAnnouncement(
    chatMember.new_chat_member.user.id,
    env
  );

  if (isEligible) {
    return;
  }

  // Remove members who are not in the Announcement Group.
  await telegramApi(

    "banChatMember",

    {
      chat_id: chatMember.chat.id,
      user_id: chatMember.new_chat_member.user.id,

      // Temporary ban (60 seconds).
      until_date: Math.floor(Date.now() / 1000) + 60

    },

    env

  );

}


/* ------------------------------------------------------------
   Check Announcement Group Membership
------------------------------------------------------------ */

async function isUserInAnnouncement(userId, env) {

  const response = await telegramApi(

    "getChatMember",

    {
      chat_id: env.TELEGRAM_ANNOUNCEMENT_CHAT_ID,
      user_id: userId
    },

    env

  );

  if (!response?.ok) {
    return false;
  }

  const status = response.result?.status;

  return (
    status === "creator" ||
    status === "administrator" ||
    status === "member"
  );

}


/* ============================================================
   END OF PART 3
============================================================ */
/* ============================================================
   LIVE INTERACTION OPERATIONS
============================================================ */


/* ------------------------------------------------------------
   Open Live Interaction Window
------------------------------------------------------------ */

async function openLiveWindow(env) {

  // Notify Announcement Group.
  await postAnnouncement(env);

  // Allow members to post.
  await setLivePermissions(env, true);

  // Notify Live Group.
  await postLiveOpen(env);

}


/* ------------------------------------------------------------
   Close Live Interaction Window
------------------------------------------------------------ */

async function closeLiveWindow(env) {

  // Notify Live Group.
  await postLiveClose(env);

  // Disable posting.
  await setLivePermissions(env, false);

}


/* ------------------------------------------------------------
   Post Community Reminder
------------------------------------------------------------ */

async function postReminder(env) {

  const message = getRandomTemplate();

  if (!message) {
    return;
  }

  await sendMessage(
    env.TELEGRAM_LIVE_CHAT_ID,
    message,
    env
  );

}


/* ------------------------------------------------------------
   Reminder Schedule
------------------------------------------------------------ */

function isReminderTime(hour, minute) {

  // Only every 15 minutes.
  if (minute % REMINDER_INTERVAL_MINUTES !== 0) {
    return false;
  }

  // Skip opening time.
  if (
    hour === LIVE_OPEN_HOUR &&
    minute === LIVE_OPEN_MINUTE
  ) {
    return false;
  }

  // Skip closing time.
  if (
    hour === LIVE_CLOSE_HOUR &&
    minute === LIVE_CLOSE_MINUTE
  ) {
    return false;
  }

  // Before opening.
  if (hour < LIVE_OPEN_HOUR) {
    return false;
  }

  // After closing.
  if (hour >= LIVE_CLOSE_HOUR) {
    return false;
  }

  return true;

}


