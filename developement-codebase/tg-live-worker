   D1 MEMBER ACTIVITY LOGGING
============================================================ */


/* ------------------------------------------------------------
   Log Member Activity
------------------------------------------------------------ */

async function logMemberActivity(

  activity,

  env

) {

  try {

    await env.LIVE_DB

      .prepare(

        `

        INSERT INTO member_activity_log (

          telegram_user_id,

          telegram_chat_id,

          action,

          reason,

          telegram_result

        )

        VALUES (?, ?, ?, ?, ?)

        `

      )

      .bind(

        activity.telegramUserId,

        activity.telegramChatId,

        activity.action,

        activity.reason,

        activity.telegramResult

      )

      .run();

  }

  catch (error) {

    console.error(

      "Failed to log member activity",

      error

    );

  }

}


/* ------------------------------------------------------------
   Approve Join Request
------------------------------------------------------------ */

async function approveJoinRequest(

  joinRequest,

  env

) {

  const response =

    await telegramApi(

      "approveChatJoinRequest",

      {

        chat_id:
          joinRequest.chat.id,

        user_id:
          joinRequest.from.id

      },

      env

    );

  await logMemberActivity(

    {

      telegramUserId:
        joinRequest.from.id,

      telegramChatId:
        joinRequest.chat.id,

      action:

        response?.ok

          ? MEMBER_ACTION.APPROVED

          : MEMBER_ACTION.ERROR,

      reason:

        response?.ok

          ? MEMBER_REASON.ELIGIBLE

          : MEMBER_REASON.API_ERROR,

      telegramResult:
        JSON.stringify(response)

    },

    env

  );

}


/* ------------------------------------------------------------
   Remove Member
------------------------------------------------------------ */

async function removeMember(

  chatMember,

  env

) {

  const response =

    await telegramApi(

      "banChatMember",

      {

        chat_id:
          chatMember.chat.id,

        user_id:
          chatMember
            .new_chat_member
            .user.id,

        until_date:

          Math.floor(

            Date.now() / 1000

          ) + 60

      },

      env

    );

  await logMemberActivity(

    {

      telegramUserId:
        chatMember
          .new_chat_member
          .user.id,

      telegramChatId:
        chatMember.chat.id,

      action:

        response?.ok

          ? MEMBER_ACTION.REMOVED

          : MEMBER_ACTION.ERROR,

      reason:

        response?.ok

          ? MEMBER_REASON.NOT_ELIGIBLE

          : MEMBER_REASON.API_ERROR,

      telegramResult:
        JSON.stringify(response)

    },

    env

  );

}


